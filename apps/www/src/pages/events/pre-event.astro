      left: 75%;
    }

    .section-1 .chair-1 {
      left: 50%;
    }

    .section-1 .bushes-1 {
      width: auto;
      left: -50%;
      bottom: -5%;
    }
    .section-1 .bushes-2 {
      display: none;
    }
    .section-1 .mailbox {
      z-index: 2;
      bottom: 0;
      position: absolute;
    }
    .section-2 .mailbox {
      position: absolute;
      height: auto;
      bottom: 0;
      width: 25vw;
      z-index: 2;
      pointer-events: none;
    }
    .section-2 .video-placeholder {
      top: 20%;
    }
    .section-2-content h3 {
      font-family: var(--font-serif);
      font-size: var(--text-l);
      font-weight: 500;
      margin: 0;
      line-height: 1.25;
      letter-spacing: -0.01em;
    }

    .section-2-content .details {
      display: flex;
      flex-direction: column;
      gap: 0.4vw;
    }

    .section-2-content .details p {
      font-family: var(--font-sans);
      font-size: var(--text-m);
      margin: 0;
