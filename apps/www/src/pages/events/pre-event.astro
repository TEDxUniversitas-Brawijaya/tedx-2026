    .section-2 .wall-2 {
      height: 100vh;
      width: auto;
      bottom: 0;
      right: 0;
      position: absolute;
    }

    .section-2 .mailbox {
      width: 30vw;
      left: 0vw;
      bottom: 4vh;
      z-index: 2;
    }

    .section-2-content {
      width: 85vw;
      left: 50%;
      top: 60%;
      position: absolute;
      height: auto;
      transform: translateX(-50%);
