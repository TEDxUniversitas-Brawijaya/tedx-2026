---
import Layout from "@/components/layout.astro";
import Navbar from "@/components/navbar.astro";
import PaperTexture from "@/assets/imgs/paper-texture-1.png";
import Image from "astro/components/Image.astro";
import Cobblestone from "@/assets/imgs/cobblestone.png";
import Trees from "@/assets/imgs/tree-1.png";
import Bushes1 from "@/assets/imgs/bushes.png";
import BuildingWithWindow from "@/assets/imgs/building-with-window.png";
import PastelCoastalLandscape from "@/assets/imgs/pastel-coastal-landscape.png";
import Chair1 from "@/assets/imgs/chair-1.png";
import Table4 from "@/assets/imgs/table-4.png";
import Bushes2 from "@/assets/imgs/bushes-2.png";
import Bushes3 from "@/assets/imgs/bushes-3.png";
import Mailbox from "@/assets/imgs/mailbox.png";
import PreEvent1 from "@/assets/imgs/pre-event-1.png";
import PreEvent2 from "@/assets/imgs/pre-event-2.png";
import Envelope from "@/assets/imgs/envelope.png";
import EnvelopeOpen from "@/assets/imgs/envelope-open.png";
---

<Layout
  title="Teras Cerita | TEDx Universitas Brawijaya"
  description="Teras Cerita merupakan gerbang awal menuju panggung utama TEDxUniversitasBrawijaya 2026, sebuah ruang bagi mahasiswa untuk mengeksplorasi makna keluarga. Kami tidak sekadar mencari pembicara mahasiswa, melainkan pemikiran tajam yang mampu membedah setiap sisi peran manusia. Pre-event hadir untuk merayakan kreativitas dan potensi generasi muda dalam memaknai kembali posisi mereka. Di bawah kurasi yang mendalam, setiap konsep akan diasah agar mampu menyampaikan pesan yang kuat dan autentik. Ini adalah panggung untuk mendefinisikan siapa kita di bawah atap yang sama, sebelum akhirnya satu suara terpilih akan bersinar di panggung utama."
>
  <Navbar />
  <div class="envelope-overlay" id="envelope-overlay"></div>
  <div class="opened-envelope-container-wrapper" id="opened-envelope-wrapper">
    <div class="opened-envelope-container">
      <Image src={EnvelopeOpen} alt="Envelope Open" class="opened-envelope" />
      <div class="envelope-content-wrapper">
        <div class="envelope-content">
          <h4>Benefit</h4>
          <ol>
            <li>
              Kesempatan mengenal lebih dekat semangat dan pengalaman khas TEDX
            </li>
            <li>
              Mendapatkan akses untuk mendengarkan insight yang disampaikan oleh
              Student Speaker dengan ide-ide segar yang menginspirasi
            </li>
            <li>
              Harga tiket sudah termasuk sajian berbuka puasa yang hangat dan
              berkesan
            </li>
            <li>
              Dapatkan voucher diskon 10% untuk pembelian tiket Main Event
            </li>
            <li>Perfume</li>
            <li>Setangkai Bunga</li>
          </ol>
          <a href="#" class="envelope-buy-btn">Buy ticket</a>
        </div>
      </div>
    </div>
  </div>
  <main>
    <section id="horizontal-scroll-section">
      <div id="sticky-wrapper">
        <div id="horizontal-canvas">
          <Image
            src={PaperTexture}
            alt={"Paper Texture"}
            class="paper-texture"
          />
          <Image
            src={PastelCoastalLandscape}
            alt={"Pastel Coastal Landscape"}
            class="pastel-coastal-landscape"
          />
          <div class="canvas-section section-1">
            <Image
              src={Cobblestone}
              alt={"Cobblestone"}
              class="cobblestone-1"
            />
            <svg
              class="wall"
              viewBox="0 0 833 609"
              fill="none"
              preserveAspectRatio="none"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
            >
              <defs>
                <pattern
                  id="paperTex"
                  patternUnits="userSpaceOnUse"
                  width="1024"
                  height="1024"
                >
                  <image
                    href={PaperTexture.src}
                    width="1024"
                    height="1024"
                    preserveAspectRatio="xMidYMid slice"
                    opacity="0.6"
                    style={{ mixBlendMode: "multiply" }}
                  />
                </pattern>
              </defs>
              <path
                d="M417 260.178V608.678H26V20H833C592.998 31.6184 417 58.6777 417 260.178Z"
                fill="black"
                fill-opacity="0.2"></path>
              <path
                d="M391 240.178V588.678H0V0H807C566.998 11.6184 391 38.6777 391 240.178Z"
                fill="white"></path>
              <path
                d="M391 240.178V588.678H0V0H807C566.998 11.6184 391 38.6777 391 240.178Z"
                fill="url(#paperTex)"></path>
            </svg>
            <Image src={Trees} alt={"trees"} class="trees" />
            <Image
              src={BuildingWithWindow}
              alt={"building-with-window"}
              class="building-with-window"
            />
            <Image src={Bushes1} alt={"bushes"} class="bushes-1" />
            <Image src={Chair1} alt={"chair"} class="chair-1" />
            <Image src={Table4} alt={"table"} class="table-4" />

            <Image src={Bushes2} alt={"bushes"} class="bushes-2" />
            <div class="section-content">
              <h2>Teras Cerita</h2>
              <p>
                Teras Cerita merupakan gerbang awal menuju panggung utama
                TEDxUniversitasBrawijaya 2026, sebuah ruang bagi mahasiswa untuk
                mengeksplorasi makna keluarga. Kami tidak sekadar mencari
                pembicara mahasiswa, melainkan pemikiran tajam yang mampu
                membedah setiap sisi peran manusia. Pre-event hadir untuk
                merayakan kreativitas dan potensi generasi muda dalam memaknai
                kembali posisi mereka. Di bawah kurasi yang mendalam, setiap
                konsep akan diasah agar mampu menyampaikan pesan yang kuat dan
                autentik. Ini adalah panggung untuk mendefinisikan siapa kita di
                bawah atap yang sama, sebelum akhirnya satu suara terpilih akan
                bersinar di panggung utama.
              </p>
            </div>
          </div>
          <div class="canvas-section section-2">
            <Image
              src={Cobblestone}
              alt={"Cobblestone"}
              class="cobblestone-1"
            />
            <div class="video-placeholder">
              <video
                src="https://cdn.tedxuniversitasbrawijaya.com/teasers/pre-event-teaser.MP4"
                autoplay
                loop
                muted
                playsinline
                controls></video>
            </div>
            <Image src={Mailbox} alt={"mailbox"} class="mailbox" />
            <Image src={Bushes3} alt={"Bushes3"} class="bushes-3" />
            <svg
              class="wall-2"
              viewBox="0 0 1061 609"
              fill="none"
              preserveAspectRatio="none"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M416 260.178V608.678H807V20H0C240.002 31.6184 416 58.6777 416 260.178Z"
                fill="black"
                fill-opacity="0.2"></path>
              <path
                d="M442 240.178V588.678H1060.5V0H26C266.002 11.6184 442 38.6777 442 240.178Z"
                fill="white"></path>
              <path
                d="M442 240.178V588.678H1060.5V0H26C266.002 11.6184 442 38.6777 442 240.178Z"
                fill="url(#paperTex)"></path>
            </svg>
            <Image src={PreEvent1} alt={"PreEvent1"} class="pre-event-1" />
            <Image src={PreEvent2} alt={"PreEvent2"} class="pre-event-2" />
            <Image
              src={Envelope}
              alt="Envelope"
              class="floating-envelope"
              id="floating-envelope"
            />
            <div class="section-2-content">
              <h3>Catat Tanggal <br /> dan Waktunya</h3>
              <div class="details">
                <p>Hari, Tanggal: Kamis</p>
                <p>12 Maret 2026</p>
                <p>Tempat: Jeda cafe</p>
              </div>
              <a href="#" class="cta-button" id="buy-ticket-btn"
                >Buy ticket for Pre Event</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    background-color: var(--color-black);
    position: relative;
  }

  #horizontal-scroll-section {
    height: 600vh;
    position: relative;
    background-color: #050505;
  }

  #sticky-wrapper {
    position: sticky;
    top: calc(var(--navbar-height, 64px) - 2px);
    left: 0;
    width: 100%;
    height: calc(100vh - var(--navbar-height, 64px) + 2px);
    overflow: hidden;
    background-color: #050505;
  }

  #horizontal-canvas {
    position: relative;
    height: 100%;
    width: 200vw;
    display: flex;
    flex-shrink: 0;
    overflow: visible;
    transform: translate(var(--translate-x, 0vw), 0%);
    will-change: transform;
    background: radial-gradient(circle at center, #111 0%, #000 100%);
  }

  .canvas-section {
    flex-shrink: 0;
    width: 100vw;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-right: -1px;
  }

  .section-content {
    position: absolute;
    z-index: 5;
    right: 5%;
    top: 40%;
    transform: translateY(-50%);
    width: 36vw;
    text-align: center;
    color: var(--color-black);
    display: flex;
    flex-direction: column;
    gap: 1.5vw;
    pointer-events: none;
  }

  .section-content h2 {
    font-family: var(--font-serif);
    font-size: 2.2vw;
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.01em;
    color: var(--color-black);
  }

  .section-content p {
    font-family: var(--font-sans);
    font-size: 1.1vw;
    margin: 0;
    font-weight: 400;
    text-align: center;
    color: var(--color-black);
    text-wrap-style: pretty;
  }

  .paper-texture {
    z-index: 50;
    position: absolute;
    top: -2px;
    left: 0;
    width: 100%;
    height: calc(100% + 4px);
    object-fit: cover;
    mix-blend-mode: multiply;
    pointer-events: none;
  }
  .cobblestone-1 {
    width: 100vw;
    height: 18vh;
    object-fit: cover;
    z-index: 2;
    position: absolute;
    bottom: 0;
  }
  .wall {
    position: absolute;
    z-index: 1;
    height: 100vh;
    width: auto;
    aspect-ratio: 833 / 608.68;
  }
  .section-1 .trees {
    z-index: 3;
    position: absolute;
    left: -18vw;
    height: 100vh;
    bottom: 0;
    width: auto;
  }

  .section-1 .building-with-window {
    position: absolute;
    z-index: 2;
    height: 100vh;
    width: auto;
    aspect-ratio: 862 / 869;
    bottom: 1;
    left: 0;
  }
  .section-1 .bushes-1 {
    position: absolute;
    z-index: 2;
    height: 35vh;
    width: 43.4vw;
    bottom: 0;
    left: 0;
  }
  .section-1 .chair-1 {
    position: absolute;
    z-index: 3;
    width: 26.25vw;
    height: 52.4vh;
    aspect-ratio: 378 / 472;
    object-fit: contain;
    bottom: -5vh;
    left: 10vw;
    pointer-events: none;
  }
  .section-1 .table-4 {
    position: absolute;
    z-index: 3;
    width: 24.3vw;
    height: auto;
    aspect-ratio: 350 / 438;
    bottom: 0;
    left: 30vw;
    pointer-events: none;
  }

  .pastel-coastal-landscape {
    position: absolute;
    z-index: 0;
    width: 200vw;
    height: calc(100% + 4px);
    top: -2px;
    left: 0;
    object-fit: cover;
    object-position: top;
    pointer-events: none;
  }
  .section-1 {
    position: relative;
    width: 100vw;
    height: 100%;
  }
  .section-2 {
    position: relative;
    width: 100vw;
    height: 100%;
  }

  .bushes-2 {
    position: absolute;
    z-index: 4;
    height: 35vh;
    width: auto;
    bottom: -4vh;
    aspect-ratio: 507/228;
    right: -25vw;
  }
  .bushes-3 {
    position: absolute;
    z-index: 4;
    height: 35.37vh;
    width: auto;
    aspect-ratio: 507.49 / 215.3;
    bottom: -4vh;
    right: -2vw;
  }

  .section-2 .mailbox {
    position: absolute;
    left: 4vw;
    bottom: -15%;
    width: 19.33vw;
    height: auto;
    aspect-ratio: 278.43 / 464.38;
    z-index: 1;
    pointer-events: none;
  }

  .section-2 .video-placeholder {
    position: absolute;
    z-index: 1;
    left: 5vw;
    top: 12vh;
    width: 45vw;
    aspect-ratio: 1045 / 588;
    background: #d9d9d9;
    border-radius: 4px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .section-2 .video-placeholder video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-2 .wall-2 {
    position: absolute;
    z-index: 0;
    width: 73.65vw;
    height: 100vh;
    aspect-ratio: 1060.5 / 608.68;
    bottom: 0;
    right: 0;
    pointer-events: none;
  }

  .section-2 .pre-event-1 {
    position: absolute;
    z-index: 3;
    width: 20.45vw;
    height: auto;
    top: 5vh;
    right: 5vw;
    pointer-events: none;
  }
  .section-2 .pre-event-2 {
    position: absolute;
    z-index: 3;
    width: 18vw;
    height: auto;
    bottom: 22vh;
    right: 0;
    transform: rotate(4deg);
    pointer-events: none;
  }

  .section-2-content {
    position: absolute;
    z-index: 5;
    right: 5vw;
    top: 50%;
    transform: translateY(-50%);
    width: 35vw;
    display: flex;
    flex-direction: column;
    gap: 2vw;
    color: var(--color-black);
    align-items: flex-start;
  }

  .section-2-content h3 {
    font-family: var(--font-serif);
    font-size: 2.2vw;
    font-weight: 500;
    margin: 0;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .section-2-content .details {
    display: flex;
    flex-direction: column;
    gap: 0.4vw;
  }

  .section-2-content .details p {
    font-family: var(--font-sans);
    font-size: 1.1vw;
    margin: 0;
    font-weight: 400;
    color: rgba(0, 0, 0, 0.85);
  }

  .section-2-content .cta-button {
    display: flex;
    justify-content: center;
    align-items: center;
    width: fit-content;
    padding: 1.2rem 2.4rem;
    background-color: #e62b1e;
    color: white;
    font-family: var(--font-serif);
    font-size: var(--text-m);
    border-radius: 0.6rem;
    text-decoration: none;
    transition: transform 0.2s ease;
    box-shadow: 0 0.4vw 1.5vw rgba(230, 43, 30, 0.3);
    position: relative;
    z-index: 6;
  }

  .section-2-content .cta-button:hover {
    transform: scale(1.05);
  }

  .floating-envelope {
    position: absolute;
    width: 25vw;
    max-width: 350px;
    height: auto;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8) rotate(0deg);
    z-index: 100;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .floating-envelope.is-animating {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) rotate(0deg);
    animation: envelope-wiggle 2s ease-in-out infinite;
  }

  @keyframes envelope-wiggle {
    0%,
    100% {
      transform: translate(-50%, -50%) scale(1) rotate(-5deg);
    }
    50% {
      transform: translate(-50%, -50%) scale(1.05) rotate(5deg);
    }
  }

  .envelope-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.85);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .envelope-overlay.is-active {
    opacity: 1;
    pointer-events: all;
  }

  .opened-envelope-container-wrapper {
    position: fixed;
    width: 420px;
    height: auto;
    top: 52%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.5);
    z-index: 1001;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.5s ease,
      transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .opened-envelope-container-wrapper.is-open {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    pointer-events: all;
  }

  .opened-envelope-container {
    position: relative;
    width: 90%;
    rotate: -4.79deg;
    height: auto;
  }

  .opened-envelope {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .envelope-content-wrapper {
    position: absolute;
    top: 65%;
    left: 45%;
    transform: translate(-50%, -50%);
    width: 86%;
    height: 82%;
    display: flex;
    flex-direction: column;
    padding: 24px 30px 10px 25px;
  }

  .envelope-content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    color: #242424;
    pointer-events: all;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .envelope-content::-webkit-scrollbar {
    display: none;
  }

  .envelope-content h4 {
    font-family: var(--font-serif);
    font-size: var(--text-l);
    margin-bottom: 20px;
  }

  .envelope-content ol {
    padding-left: 18px;
    margin: 0 0 12px 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .envelope-content li {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.15;
    font-weight: 400;
  }

  .envelope-buy-btn {
    margin-bottom: 24px;
    margin-right: 4px;
    align-self: flex-end;
    background-color: #dc2625;
    color: white;
    font-family: var(--font-serif);
    font-size: var(--text-m);
    padding: 8px 24px;
    border-radius: 6px;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease;
    box-shadow: 0 0.5rem 1.5rem rgba(230, 43, 30, 0.4);
  }

  .envelope-buy-btn:hover {
    transform: scale(1.05) rotate(1deg);
    background-color: #cf261b;
  }

  @media (max-width: 767px) {
    .wall {
      height: 100vh;
      width: auto;
      bottom: 0vh;
      left: 0vw;
      position: absolute;
    }

    .section-1 .trees {
      display: none;
    }

    .section-1 .building-with-window {
      display: none;
    }

    .section-2 .bushes-2 {
      /* display: none; */
    }
    .bushes-3 {
      display: none;
    }
    .bushes-2 {
      position: absolute;
      height: auto;
      aspect-ratio: 258.46 / 116.57;
      bottom: 0vh;
      right: -64vw;
      z-index: 4;
    }

    .section-2 .video-placeholder {
      width: 17rem;
      max-width: 17rem;
      aspect-ratio: 309 / 370;
      left: 50%;
      top: 5vh;
      z-index: 23;
      position: absolute;
      transform: translateX(-50%);
    }

    .section-2 .wall-2 {
      height: 100vh;
      width: auto;
      bottom: 0;
      right: 0;
      position: absolute;
    }

    .section-2 .mailbox {
      width: 30vw;
      left: 0vw;
      bottom: 4vh;
      z-index: 2;
    }

    .section-2-content {
      width: 85vw;
      left: 50%;
      top: 65%;
      position: absolute;
      height: auto;
      transform: translateX(-50%);
      align-items: center;
      text-align: center;
      gap: 1.2vh;
      z-index: 5;
    }

    .section-2-content h3 {
      font-size: var(--text-l);
      line-height: 1.2;
      font-weight: 500;
    }

    .section-2-content .details {
      font-size: var(--text-m);
      gap: 0.4vh;
    }

    .section-2-content .details p {
      font-size: 0.9rem;
      color: rgba(0, 0, 0, 0.85);
    }

    .section-2-content .cta-button {
      padding: 0.6rem 1.4rem;
      margin-top: 1vh;
    }

    .section-1 .bushes-1 {
      height: 20vh;
      width: auto;
      position: absolute;
      bottom: -1vh;
      left: -60vw;
    }

    .section-1 .table-4 {
      position: absolute;
      width: 40vw;
      height: auto;
      bottom: 4vh;
    }

    .section-1 .chair-1 {
      width: 40vw;
      height: auto;
      bottom: 2vh;
      left: 0vw;
      position: absolute;
    }
    .cobblestone-1 {
      width: 100vw;
      height: 14%;
      position: absolute;
      bottom: 0;
    }

    .section-1 .section-content {
      width: 85vw;
      left: 50%;
      top: 35%;
      transform: translate(-50%, -50%);
      gap: 1rem;
    }

    .section-1 .section-content h2 {
      font-size: var(--text-l);
      letter-spacing: normal;
    }

    .section-1 .section-content p {
      font-size: var(--text-s);
      line-height: inherit;
      width: 90%;
      max-width: none;
      margin: auto;
    }

    .pastel-coastal-landscape {
      object-position: 50% 10%;
      height: 150vh;
      top: 0;
    }

    .section-2 .pre-event-1 {
      width: 80vw;
      top: 5vh;
      z-index: 1;
      position: absolute;
      right: -50vw;
    }

    .section-2 .pre-event-2 {
      width: 60vw;
      bottom: 20vh;
      z-index: 1;
      right: -45vw;
    }

    .floating-envelope {
      width: 80vw;
    }

    .opened-envelope-container-wrapper {
      width: 90%;
      left: 50%;
      top: 50%;
    }

    .envelope-content-wrapper {
      top: 65%;
      left: 47%;
      width: 90%;
      height: 78%;
      padding: 24px 25px 10px 25px;
    }

    .envelope-content h4 {
      font-size: 18px;
      margin-bottom: 20px;
    }

    .envelope-content li {
      font-size: 11px;
