<script>
  (() => {
    const section = document.getElementById("horizontal-scroll-section");
    const canvas = document.getElementById("horizontal-canvas");

    if (!(section && canvas)) {
      return;
    }

    const easeInOutCubic = (t: number): number => {
      return t < 0.5 ? 4 * t * t * t : 1 - (-2 * t + 2) ** 3 / 2;
    };

    function transform(
      x: number,
      input: number[],
      output: number[],
      easing: (t: number) => number = (t) => t,
    ) {
      const firstInput = input[0];
      const lastInput = input.at(-1);
      const lastOutput = output.at(-1);

      if (
        firstInput === undefined ||
        lastInput === undefined ||
        lastOutput === undefined
      ) {
        return 0;
      }

      const clampedX = Math.max(firstInput, Math.min(lastInput, x));

      for (let i = 0; i < input.length - 1; i++) {
        const currentInput = input[i];
        const nextInput = input[i + 1];
        const currentOutput = output[i];
        const nextOutput = output[i + 1];

        if (
          currentInput !== undefined &&
          nextInput !== undefined &&
          currentOutput !== undefined &&
          nextOutput !== undefined &&
          clampedX >= currentInput &&
          clampedX <= nextInput
        ) {
          const localProgress =
            (clampedX - currentInput) / (nextInput - currentInput);
          const easedProgress = easing(localProgress);
          return currentOutput + easedProgress * (nextOutput - currentOutput);
        }
      }

      return lastOutput;
    }

    const updateScroll = () => {
      const sectionRect = section.getBoundingClientRect();
      const sectionHeight = section.offsetHeight;
      const viewportHeight = window.innerHeight;

      const scrollProgress = Math.max(
        0,
        Math.min(1, -sectionRect.top / (sectionHeight - viewportHeight)),
      );

      const translateX = transform(
        scrollProgress,
        [0, 1],
        [0, -100],
        easeInOutCubic,
      );

      canvas.style.setProperty("--translate-x", `${translateX}vw`);
    };

    let scrollRafId: number | null = null;
    window.addEventListener(
      "scroll",
      () => {
        if (scrollRafId !== null) {
          return;
        }
        scrollRafId = requestAnimationFrame(() => {
          updateScroll();
          scrollRafId = null;
        });
      },
      { passive: true },
    );

    updateScroll();

    document.addEventListener("astro:page-load", updateScroll);

    const buyBtn = document.getElementById("buy-ticket-btn");
    const envelope = document.getElementById("floating-envelope");
    const envelopeOpen = document.getElementById("opened-envelope-wrapper");
    const overlay = document.getElementById("envelope-overlay");

    if (buyBtn && envelope && envelopeOpen && overlay) {
      buyBtn.addEventListener("click", (e) => {
        e.preventDefault();
        envelope.classList.add("is-animating");

        setTimeout(() => {
          envelope.classList.remove("is-animating");
          overlay.classList.add("is-active");
          envelopeOpen.classList.add("is-open");
        }, 1500);
      });

      overlay.addEventListener("click", () => {
        overlay.classList.remove("is-active");
        envelopeOpen.classList.remove("is-open");
      });
    }
  })();
</script>
