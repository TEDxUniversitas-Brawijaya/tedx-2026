---
import Layout from "@/components/layout.astro";
import { Image } from "astro:assets";
import backgroundImage from "@/assets/imgs/green-room-background-3.png";
import floor from "@/assets/imgs/wood-floor.png";
import texture from "@/assets/imgs/paper-grain-texture-1.png";
import window from "@/assets/imgs/window-2.png";
import lighting from "@/assets/svgs/window-lighting.svg";
import lamp from "@/assets/imgs/chandelier-1.png";
import sofa from "@/assets/imgs/sofa-1.png";
import table from "@/assets/imgs/table-2.png";
import chair from "@/assets/imgs/side-chair.png";
import carpet from "@/assets/imgs/green-carpet.png";
import diningTable from "@/assets/imgs/dining-seat.png";
import vase from "@/assets/imgs/flower-vase.png";
import vaseShine from "@/assets/svgs/flower-vase-shine.svg";
import Navbar from "@/components/navbar.astro";
import curtain from "@/assets/imgs/curtain.png";
import desk from "@/assets/imgs/desk.png";
import brokenVase from "@/assets/imgs/broken-vase-flower.png";
import flowerStalk from "@/assets/imgs/flower-stalk.png";
import bookShelf from "@/assets/imgs/book-shelf.png";
import photoFrame from "@/assets/imgs/photo-frame.png";
import photoFrame2 from "@/assets/imgs/photo-frame-2.png";
import photoFrame3 from "@/assets/imgs/photo-frame-3.png";
import silPerson from "@/assets/svgs/silhouette-of-person.svg";
import standLamp from "@/assets/imgs/stand-lamp.png";
import headSofa from "@/assets/imgs/head-sofa.png";
import "@/styles/propaganda-2.css";
---

<Layout
  title="Antologi Rasa | TEDx Universitas Brawijaya"
  description="Jauh sebelum kita mengenal kata-kata, perasaan adalah cara pertama manusia berkomunikasi dengan dunia. Di dalam lingkungan keluarga, emosi berperan sebagai jembatan utama bagi kita untuk memahami diri sendiri sekaligus orang-orang di sekitar. Keluarga yang harmonis bukan berarti keluarga yang selalu tenang tanpa perselisihan, melainkan keluarga yang berani memberi ruang bagi setiap anggotanya untuk merasa bahagia, sedih, hingga kecewa tanpa perlu merasa dihakimi. Dengan menghargai setiap rasa yang muncul, kita belajar bahwa memiliki emosi bukanlah sebuah kelemahan, melainkan bukti nyata bahwa kita adalah manusia yang utuh."
>
  <Navbar />
  <main id="propa2-main">
    <!-- frame 1 -->
    <section class="frame-1" style="position: relative;">
      <Image src={backgroundImage} class="background" alt="Propaganda 2" />
      <Image src={floor} class="floor" alt="Wood Floor" />
      <div class="window-1-container">
        <Image src={window} class="window-1" alt="Window-1" />
        <Image src={lighting} class="lighting" alt="Window Lighting" />
      </div>
      <Image src={lamp} class="hanging-lamp" alt="Hanging Lamp" />
      <Image src={sofa} class="sofa" alt="Sofa" />
      <Image src={table} class="table" alt="table" />
      <Image src={chair} class="chair" alt="chair" />
      <Image src={chair} class="mirror-chair" alt="chair2" />
      <div class="text">
        <h3 style="font-size: 1.5rem;">ANTOLOGI RASA</h3>
        <p>
          Jauh sebelum kita mengenal kata-kata, perasaan adalah cara pertama
          manusia berkomunikasi dengan dunia. Di dalam lingkungan keluarga,
          emosi berperan sebagai jembatan utama bagi kita untuk memahami diri
          sendiri sekaligus orang-orang di sekitar. Keluarga yang harmonis bukan
          berarti keluarga yang selalu tenang tanpa perselisihan, melainkan
          keluarga yang berani memberi ruang bagi setiap anggotanya untuk merasa
          bahagia, sedih, hingga kecewa tanpa perlu merasa dihakimi. Dengan
          menghargai setiap rasa yang muncul, kita belajar bahwa memiliki emosi
          bukanlah sebuah kelemahan, melainkan bukti nyata bahwa kita adalah
          manusia yang utuh.
        </p>
      </div>
    </section>
    <!-- frame 2 -->
    <section class="frame-2" style="position: relative;">
      <div class="frame-2-sticky-wrapper">
        <Image src={carpet} class="carpet" alt="Green Carpet" />
        <Image src={floor} class="floor-frame-2" alt="Wood Floor" />
        <div class="frame-2-content">
          <!-- <div class="placeholder">placeholder</div> -->
          <p
            class="text-2-content"
            style={{ fontFamily: 'var(--font-sans)', fontSize: '1rem' }}
          >
            Dalam perspektif yang lebih luas, topik ini mengajak kita melihat
            bagaimana elemen modern seperti teknologi dan hiburan mempengaruhi
            cara kita mengelola perasaan. Teknologi saat ini berperan besar
            dalam membantu atau justru menghambat cara kita mengekspresikan
            diri, sementara hiburan sering menjadi tempat kita melepas beban
            batin dan mencari makna hidup. Tantangan besarnya adalah bagaimana
            kita dapat merancang pola komunikasi dan interaksi sosial yang lebih
            terbuka. Tujuannya agar tercipta ruang dialog yang jujur, aman, dan
            merangkul semua orang, baik di dalam lingkup kecil keluarga maupun
            di tengah masyarakat luas.
          </p>
        </div>
      </div>
    </section>
    <!-- frame 3 -->
    <section class="frame-3" style="position: relative;">
      <div class="window-container-3">
        <div class="window-wrapper-3">
          <Image src={window} class="window-frame-3" alt="Window 2" />
          <Image src={window} class="window-frame-3" alt="Window 2" />
          <Image src={curtain} class="curtain" alt="Curtain" />
          <Image src={curtain} class="curtain2" alt="Curtain" />
        </div>
      </div>
      <Image src={backgroundImage} class="background" alt="Propaganda 2" />
      <Image src={diningTable} class="dining-table" alt="Dining Table" />
      <div class="vase-container">
        <div class="vase-wrapper">
          <Image src={vase} class="vase" alt="Flower Vase" />
          <Image src={vaseShine} class="vase-shine" alt="Vase Shine" />
        </div>
      </div>
      <div class="text-3">
        <h3 style="font-size: 1.5rem;">PRASASTI TANPA AKSARA</h3>
        <p>
          Sebelum lidah mampu mengeja kata dan logika mulai menyusun alasan,
          manusia telah lebih dulu "berbicara" melalui getaran perasaan. Bagian
          ini menjelaskan bahwa rasa adalah medium komunikasi yang paling jujur.
          Dalam lingkup keluarga, rasa bukan sekadar reaksi, melainkan kompas
          pertama bagi seorang individu untuk mengenali siapa dirinya dan siapa
          orang di sekitarnya.
        </p>
      </div>
    </section>
    <!-- frame 4 -->
    <section
      class="frame-4"
      style="position: relative; background-color: #312E35; min-height: 100vh;"
    >
      <div class="text-4">
        <p>
          Di sini, kita membedah bahwa emosi, baik itu kegelapan rasa takut
          maupun cahaya kebahagiaan memiliki hak yang sama untuk hadir. Mengakui
          rasa tanpa penyangkalan adalah bentuk penghormatan paling dasar
          terhadap martabat manusia, karena sebelum kita menjadi makhluk yang
          berpikir, kita adalah makhluk yang merasa.
        </p>
      </div>
    </section>
    <!-- frame 5 wrapper -->
    <div class="frame-5-wrapper">
      <!-- frame 5 -->
      <section class="frame-5">
        <Image src={desk} class="desk-frame-4" alt="desk" />
        <Image src={floor} class="floor-frame-5" alt="Propaganda 2" />
        <!-- <div class="placeholder-frame-5">placeholder</div> -->
        <div class="broken-vase-container">
          <div class="broken-vase-wrapper">
            <Image
              src={brokenVase}
              class="broken-vase"
              alt="Broken Vase with Flowers"
            />
            <Image src={flowerStalk} class="flower-stalk" alt="Flower Stalk" />
          </div>
        </div>
      </section>
    </div>
    <div style="display: grid; width: 100%;">
      <!-- frame 6 wrapper -->
      <div class="frame-6-wrapper" style="grid-area: 1 / 1;">
        <!-- frame 6 -->
        <section class="frame-6">
          <Image src={backgroundImage} class="background" alt="Propaganda 2" />
          <Image src={bookShelf} class="book-shelf" alt="Book Shelf" />
          <Image src={bookShelf} class="book-shelf-2" alt="Book Shelf" />
          <Image src={floor} class="floor-frame-6" alt="Propaganda 2" />
          <Image src={photoFrame} class="photo-frame" alt="Photo Frame" />
          <Image src={desk} class="desk-frame-6" alt="desk" />
          <div class="broken-vase-container-frame-6">
            <div class="broken-vase-wrapper-frame-6">
              <Image
                src={brokenVase}
                class="broken-vase-frame-6"
                alt="Broken Vase with Flowers"
              />
              <Image
                src={flowerStalk}
                class="flower-stalk-frame-6"
                alt="Flower Stalk"
              />
            </div>
          </div>
        </section>
      </div>

      <!-- text wrapper overlay -->
      <div
        class="text-frame-6-wrapper"
        style="grid-area: 1 / 1; width: 100%; height: 350vh; pointer-events: none; z-index: 6;"
      >
        <div style="position: sticky; top: 0; width: 100%; height: 100vh;">
          <div
            class="text-frame-6"
            style="display:grid; gap:1.5rem; pointer-events: auto;"
          >
            <h3>RUANG TEDUH</h3>
            <span style="display:grid; gap:1rem">
              <p>
                Menggugat pemahaman umum bahwa keluarga yang ideal adalah
                keluarga yang sunyi dari pertikaian. Secara rincinya, menekankan
                bahwa kesehatan sebuah keluarga justru diuji dalam konflik.
                Keharmonisan sejati tidak dibangun di atas keheningan yang
                dipaksakan, melainkan di atas kemampuan sebuah sistem (keluarga)
                untuk menjadi "wadah" yang cukup besar bagi emosi-emosi yang
                meledak.
              </p>
              <p>
                Empati dan kesadaran bertindak sebagai jangkar agar badai emosi
                tersebut tidak menghancurkan, melainkan mempererat ikatan.
                Menghargai rasa berarti memahami bahwa emosi bukan tanda
                kerapuhan atau kelemahan, melainkan "alarm" kemanusiaan yang
                menandakan bahwa ada sesuatu yang sedang beresonansi di dalam
                batin kita.
              </p>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- frame 7 & 8 dissolve wrapper -->
    <div class="frame-7-8-wrapper">
      <!-- frame 7 track -->
      <div class="frame-7-track">
        <section class="frame-7">
          <Image src={floor} class="floor-frame-7" alt="Wood Floor" />
          <div class="placeholder-frame-7">placeholder</div>
          <Image
            src={silPerson}
            class="sil-person"
            alt="Silhouette of Person"
          />
        </section>
      </div>

      <!-- frame 8 track -->
      <div class="frame-8-scroll">
        <section class="frame-8">
          <Image
            src={backgroundImage}
            class="background-frame-8"
            alt="Propaganda 2 Frame 8 Background"
          />
          <Image src={photoFrame3} class="photo-frame-3" alt="Photo Frame" />
          <Image src={photoFrame2} class="photo-frame-2" alt="Photo Frame" />
        </section>
      </div>

      <!-- text wrapper overlay -->
      <div
        class="text-frame-8-wrapper"
        style="grid-area: 1 / 1; width: 100%; height: 250vh; pointer-events: none; z-index: 6;"
      >
        <div style="position: sticky; top: 0; width: 100%; height: 100vh;">
          <div
            class="text-frame-8"
            style="display:grid; gap:2rem; pointer-events: auto;"
          >
            <h3>JEMBATAN RASA</h3>
            <span style="display:grid; gap:1rem">
              <p>
                Kita merefleksikan bagaimana emosi manusia berinteraksi dengan
                dunia modern. Bagian ini membahas peran media (teknologi,
                hiburan, dan desain) dalam memfasilitasi dialog perasaan. Di
                tengah dunia yang semakin digital, tantangannya adalah bagaimana
                menciptakan desain komunikasi yang tidak dingin, melainkan mampu
                memediasi kejujuran emosional.
              </p>
              <p>
                Hiburan berperan sebagai ruang katarsis, tempat kita melepas
                beban perasaan, sementara desain interaksi harus bertujuan
                menciptakan ruang yang aman dan inklusif. Tujuannya adalah agar
                teknologi dan seni tidak menjauhkan kita dari hakikat rasa,
                melainkan menjadi jembatan yang memungkinkan setiap individu di
                dalam keluarga maupun masyarakat luas untuk saling terhubung
                dalam frekuensi emosi yang jujur dan aman.
              </p>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- frame 9 -->
    <section class="frame-9">
      <Image
        src={backgroundImage}
        class="background-frame-9"
        alt="Propaganda 2 Frame 9 Background"
      />
      <div class="placeholder-frame-9">placeholder</div>
      <Image src={standLamp} class="stand-lamp" alt="Stand Lamp" />
      <Image src={headSofa} class="head-sofa" alt="Head Sofa" />
    </section>

    <Image src={texture} class="texture" alt="Paper Grain Texture" />
  </main>
</Layout>

<script>
  import Lenis from "lenis";

  const easeOutCubic = (t: number) => 1 - (1 - t) ** 3;
  const easeInOutCubic = (t: number) =>
    t < 0.5 ? 4 * t * t * t : 1 - (-2 * t + 2) ** 3 / 2;

  new Lenis({ autoRaf: true });

  const vaseWrapper = document.querySelector(".vase-wrapper") as HTMLElement;
  const mainContent = document.querySelector("#propa2-main") as HTMLElement;
  const frame3 = document.querySelector(".frame-3") as HTMLElement;
  const text3 = document.querySelector(".text-3") as HTMLElement;
  const frame4 = document.querySelector(".frame-4") as HTMLElement;
  const text4 = document.querySelector(".text-4") as HTMLElement;
  const frame5Wrapper = document.querySelector(
    ".frame-5-wrapper"
  ) as HTMLElement;
  const frame5 = document.querySelector(".frame-5") as HTMLElement;
  const frame6Wrapper = document.querySelector(
    ".frame-6-wrapper"
  ) as HTMLElement;
  const frame6 = document.querySelector(".frame-6") as HTMLElement;
  const textFrame6 = document.querySelector(".text-frame-6") as HTMLElement;

  const frame8Scroll = document.querySelector(".frame-8-scroll") as HTMLElement;
  const frame8 = document.querySelector(".frame-8") as HTMLElement;
  const textFrame8 = document.querySelector(".text-frame-8") as HTMLElement;

  // const placeholderFrame5 = document.querySelector(
  //   ".placeholder-frame-5"
  // ) as HTMLElement;

  // Frame 2 animation elements (placeholder hidden)
  const frame2Section = document.querySelector(".frame-2") as HTMLElement;
  const text2Content = document.querySelector(".text-2-content") as HTMLElement;
  // const placeholder2 = document.querySelector(
  //   ".frame-2 .placeholder"
  // ) as HTMLElement;

  if (vaseWrapper) {
    vaseWrapper.style.willChange = "transform";
  }
  if (text3) {
    text3.style.willChange = "opacity";
  }
  if (text4) {
    text4.style.willChange = "opacity";
  }
  // if (placeholderFrame5) {
  //   placeholderFrame5.style.willChange = "opacity";
  // }
  if (text2Content) {
    text2Content.style.willChange = "opacity";
  }
  if (frame6Wrapper) {
    frame6Wrapper.style.willChange = "filter";
    frame6Wrapper.style.filter = "brightness(0)";
  }
  if (frame6) {
    frame6.style.willChange = "transform";
  }
  if (textFrame6) {
    textFrame6.style.willChange = "opacity";
    textFrame6.style.opacity = "0";
  }
  if (textFrame8) {
    textFrame8.style.willChange = "opacity";
    textFrame8.style.opacity = "0";
  }
  // if (placeholder2) {
  //   placeholder2.style.willChange = "opacity";
  // }

  const isMobile = () => window.innerWidth <= 768;

  const handleFrame2TextFade = () => {
    if (!(frame2Section && text2Content)) {
      return;
    }

    const rect = frame2Section.getBoundingClientRect();
    const scrolled = -rect.top;
    const maxScroll = frame2Section.offsetHeight - window.innerHeight;

    if (maxScroll <= 0) {
      return;
    }

    const rawProgress = Math.min(Math.max(scrolled / maxScroll, 0), 1);
    // Teks fade-out di 60% pertama scroll frame-2
    const rawTextOut = Math.min(Math.max(rawProgress / 0.6, 0), 1);
    const textOpacity = 0 + easeInOutCubic(rawTextOut);
    text2Content.style.opacity = textOpacity.toString();
  };

  const initFrame2Mobile = () => {
    if (text2Content) {
      text2Content.style.zIndex = "6";
      text2Content.style.opacity = "1";
    }
  };

  initFrame2Mobile();

  const updateFrame5State = () => {
    const f5Rect = frame5?.getBoundingClientRect();
    if (!f5Rect) {
      return;
    }

    const frame5Bottom = f5Rect.bottom;
    const isFrame5BottomInViewport = frame5Bottom <= window.innerHeight + 80;
    if (isFrame5BottomInViewport) {
      mainContent?.classList.add("is-vase-broken");
    } else {
      mainContent?.classList.remove("is-vase-broken");
    }

    if (frame5Wrapper) {
      const wrapperRect = frame5Wrapper.getBoundingClientRect();
      const maxScroll = wrapperRect.height - f5Rect.height;
      const stickyStartPoint = window.innerHeight - f5Rect.height;
      let scrolledPastSticky = stickyStartPoint - wrapperRect.top;

      if (scrolledPastSticky < 0) {
        scrolledPastSticky = 0;
      }
      if (scrolledPastSticky > maxScroll) {
        scrolledPastSticky = maxScroll;
      }

      const rawProgress = maxScroll > 0 ? scrolledPastSticky / maxScroll : 0;
      const brightness = 1 - easeInOutCubic(rawProgress);
      frame5Wrapper.style.filter = `brightness(${brightness})`;
    }
  };

  const handleFrame6Scroll = () => {
    if (!(frame6Wrapper && frame6)) {
      return;
    }
    const f6WrapperRect = frame6Wrapper.getBoundingClientRect();
    const distancePastTop = -f6WrapperRect.top;

    if (distancePastTop <= 0) {
      frame6Wrapper.style.filter = "brightness(0)";
      frame6.style.transform = "scale(1)";
      if (textFrame6) {
        textFrame6.style.opacity = "0";
      }
    } else {
      const vh = window.innerHeight;
      const fadeDistance = vh * 0.5;

      const brightnessProgress = Math.min(distancePastTop / fadeDistance, 1);

      const brightness = easeInOutCubic(brightnessProgress);
      frame6Wrapper.style.filter = `brightness(${brightness})`;

      let scale = 1;
      let textOpacity = 0;
      if (brightness >= 0.01) {
        scale = 2.2;
        if (distancePastTop > vh) {
          const scaleDistance = distancePastTop - vh;
          const maxScaleDistance = vh * 1.5;
          const rawScaleProgress = Math.min(
            scaleDistance / maxScaleDistance,
            1
          );
          const scaleProgress = easeOutCubic(rawScaleProgress);
          scale = 2.2 - 1.2 * scaleProgress;

          if (scale <= 1.2) {
            textOpacity = (1.2 - scale) / 0.2;
            textOpacity = Math.max(0, Math.min(1, textOpacity));
          }
        }
      }
      frame6.style.transform = `scale(${scale})`;
      if (textFrame6) {
        textFrame6.style.opacity = textOpacity.toString();
      }
    }
  };

  if (vaseWrapper && frame3) {
    const handleFrame3Scroll = (mobile: boolean) => {
      const f3Rect = frame3.getBoundingClientRect();
      const scrollPastBottomFrame3 = window.innerHeight - f3Rect.bottom;

      if (scrollPastBottomFrame3 > 0) {
        const fadeDivisor = mobile ? 160 : 100;
        const rawFade = Math.min(scrollPastBottomFrame3 / fadeDivisor, 1);
        const textOpacity = mobile ? 1 : Math.max(1 - easeOutCubic(rawFade), 0);

        const moveMultiplier = mobile ? 1.05 : 1.1;
        const rotateMultiplier = mobile ? 0.045 : 0.045;
        const scale =
          1 + (scrollPastBottomFrame3 / (mobile ? 200 : 100)) * 0.03;
        const moveY = scrollPastBottomFrame3 * moveMultiplier;
        const rotate = scrollPastBottomFrame3 * rotateMultiplier;

        if (!mobile) {
          text3.style.opacity = textOpacity.toString();
        }
        vaseWrapper.style.transform = `translateY(${moveY}px) rotate(${rotate}deg) scale(${scale})`;
      }
    };

    const handleFrame4Scroll = (mobile: boolean) => {
      const f4Rect = frame4.getBoundingClientRect();
      const viewportCenter = window.innerHeight / 2;
      const distanceToCenter = f4Rect.top - viewportCenter;

      if (distanceToCenter <= 0) {
        const opacityRamp = mobile ? 200 : 350;
        const rawOpacity = Math.min(
          1,
          Math.abs(distanceToCenter) / opacityRamp
        );
        const textOpacity = easeOutCubic(rawOpacity);
        text4.style.opacity = textOpacity.toString();
        text4.style.zIndex = textOpacity >= 1 ? "6" : "1";

        const f3RectNow = frame3.getBoundingClientRect();
        const scrollPastBottom = window.innerHeight - f3RectNow.bottom;
        if (scrollPastBottom > 0) {
          const moveMultiplier = 1.05;
          const rotateMultiplier = mobile ? 0.045 : 0.05;
          const scale4 = 1 + (scrollPastBottom / (mobile ? 200 : 100)) * 0.03;
          const moveY4 = scrollPastBottom * moveMultiplier;
          const rotate4 = scrollPastBottom * rotateMultiplier;
          vaseWrapper.style.transform = `translateY(${moveY4}px) rotate(${rotate4}deg) scale(${scale4})`;
        }
      } else {
        text4.style.opacity = "0";
      }
    };

    const handleFrame7Scroll = () => {
      if (!(frame8Scroll && frame8 && textFrame8)) {
        return;
      }
      const rect = frame8Scroll.getBoundingClientRect();
      const distancePastTop = -rect.top;

      if (distancePastTop <= 0) {
        frame8.style.opacity = "0";
        textFrame8.style.opacity = "0";
      } else {
        const maxScroll = window.innerHeight * 1.5;
        const rawProgress = Math.min(distancePastTop / maxScroll, 1);
        const opacityProgress = easeInOutCubic(rawProgress);
        frame8.style.opacity = opacityProgress.toString();
        textFrame8.style.opacity = opacityProgress.toString();
      }
    };

    let scrollRafId: number | null = null;
    window.addEventListener(
      "scroll",
      () => {
        if (scrollRafId !== null) {
          return;
        }
        scrollRafId = requestAnimationFrame(() => {
          const mobile = isMobile();
          handleFrame2TextFade();
          handleFrame3Scroll(mobile);
          handleFrame4Scroll(mobile);
          updateFrame5State();
          handleFrame6Scroll();
          handleFrame7Scroll();
          scrollRafId = null;
        });
      },
      { passive: true }
    );

    updateFrame5State();

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        initFrame2Mobile();
        updateFrame5State();
        if (isMobile()) {
          text3.style.opacity = "1";
        }
      }, 150);
    });
  }
</script>
