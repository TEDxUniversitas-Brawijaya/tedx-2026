---
import { Image } from "astro:assets";
import Layout from "@/components/layout.astro";
import Navbar from "@/components/navbar.astro";
import PaperTexture1 from "@/assets/imgs/paper-texture-1.png";
import Seesaw from "@/assets/imgs/seesaw.png";
import Playground from "@/assets/imgs/playground.png";
import Grass from "@/assets/imgs/grass.png";
import BouquetStand from "@/assets/imgs/bouquet-stand.png";
import FlowerPot1 from "@/assets/imgs/flower-pot-1.png";
import FlowerPot2 from "@/assets/imgs/flower-pot-2.png";
import Guidebook from "@/assets/imgs/guidebook.png";
import Tree from "@/assets/imgs/tree-1.png";
import Picnic from "@/assets/imgs/picnic.png";
---

<Layout>
  <Navbar />
  <section id="section-one">
    <div class="section-one-wrapper">
      <div id="horizontal-scroll" class="horizontal-scroll">
        <div class="background-container-wrapper">
          <div class="background-container">
            <Image src={Seesaw} alt="Seesaw" class="seesaw" />
            <Image src={Playground} alt="Playground" class="playground" />
            <Image src={Grass} alt="Grass" class="grass" />
            <Image src={Tree} alt="Tree" class="tree" />
            <Image src={Picnic} alt="Picnic" class="picnic" />
            <Image
              src={BouquetStand}
              alt="Bouquet Stand"
              class="bouquet-stand"
            />
            <Image src={FlowerPot1} alt="Flower Pot 1" class="flower-pot-1" />
            <Image src={FlowerPot2} alt="Flower Pot 2" class="flower-pot-2" />
          </div>
        </div>
        <div class="first-screen">
          <div class="text-container">
            <h2>BINGKAI KASIH</h2>
            <p>
              Bingkai Kasih akan mengeksplorasi interaksi penuh empati yang
              merupakan pilar penting dalam konsep keluarga. Ruang ini tidak
              hanya mempertemukan individu, tetapi juga merawat rasa memiliki
              yang memperkuat hubungan antarsesama. Setiap keterlibatan menjadi
              wujud nyata bahwa kebersamaan dapat dibangun melalui tindakan
              sederhana yang penuh makna.
            </p>
          </div>
          <div class="text-container">
            <p>
              Kegiatan yang akan dilakukan adalah membuat bento, menghias kue
              mangkuk, dan merangkai bunga. Pelaksanaan kegiatan akan dikemas
              secara hangat, dan pada akhirnya akan memberikan kesan yang dalam
              kepada partisipan sebagai sebuah keluarga tanpa ikatan darah.
              Harapannya dengan dilaksanakan kegiatan ini dapat memantik apa
              arti keluarga menurut masing-masing individu.
            </p>
          </div>
        </div>
        <div class="third-screen">
          <div class="text-container">
            <h2>DAY 1: MERANGKAI BUNGA</h2>
            <p>
              Bunga sering menjadi simbol kasih—keindahan yang tumbuh dari
              perhatian kecil dan kehangatan yang tulus. Melalui kegiatan
              merangkai bunga, para partisipan diajak untuk menata keindahan
              warna dan bentuk bunga dengan tangan mereka sendiri, seakan
              menghadirkan kembali kenangan tentang kasih yang pernah mereka
              berikan kepada keluarga, sahabat, dan orang-orang di sepanjang
              perjalanan hidupnya. Dari rangkaian sederhana itu, kita diingatkan
              bahwa kasih tidak pernah benar-benar hilang, ia tetap hidup dan
              mekar dalam kenangan.
            </p>
          </div>
        </div>
        <div class="fourth-screen">
          <div class="text-container">
            <h2>DAY 2: MEMBUAT BENTO</h2>
            <p>
              Membuat bento menjadi ruang sederhana bagi partisipan untuk
              merangkai makna pulang melalui bekal yang mereka susun bersama.
              Kotak bento yang membingkai hidangan di dalamnya menjadi seperti
              dinding rumah yang menghadirkan rasa aman. Sementara nasi, lauk,
              dan sayur yang menemani di sampingnya menggambarkan berbagai
              kehadiran yang saling melengkapi dan membuat sebuah rumah terasa
              lebih hidup. Dari susunan sederhana itu, membuat bento menjadi
              seperti menata tempat untuk berpulang—ruang hangat di mana setiap
              unsur di dalamnya saling menjaga dan memberi rasa untuk kembali.
            </p>
          </div>
        </div>
        <div class="fifth-screen">
          <div class="guidebook-content">
            <h2>GUIDEBOOK</h2>
            <Image
              src={Guidebook}
              alt="Guidebook Pre Event"
              class="guidebook"
            />
            <div class="guidebook-actions">
              <button
                type="button"
                class="guidebook-button guidebook-button-guidebook"
              >
                Baca Guidebook
              </button>
              <button
                type="button"
                class="guidebook-button guidebook-button-ticket"
              >
                Buy ticket Pre Event
              </button>
            </div>
          </div>
        </div>
      </div>
      <Image src={PaperTexture1} alt="Paper Texture" class="paper-texture-1" />
    </div>
  </section>
</Layout>

<style>
  #section-one {
    position: relative;
    height: 700dvh;
    --max-horizontal-scroll-vw: 650;
  }

  #section-one .section-one-wrapper {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    background-color: var(--color-white);
  }

  #section-one .horizontal-scroll {
    --translate-x: 0dvw;
    position: relative;
    display: flex;
    width: 100%;
    height: 100dvh;
    transform: translate(var(--translate-x), 0%);
    will-change: transform;
  }

  #section-one .background-container-wrapper {
    position: absolute;
    inset: 0;
    width: 980dvw;
    height: 100dvh;
    z-index: 1;
  }

  #section-one .background-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  #section-one .first-screen {
    position: relative;
    width: 200dvw;
    height: 100dvh;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: row;
    gap: 5rem;
    z-index: 3;
  }

  #section-one .second-screen,
  #section-one .third-screen,
  #section-one .fourth-screen,
  #section-one .fifth-screen {
    position: relative;
    width: 100dvw;
    height: 100dvh;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 10dvw;
    z-index: 3;
  }

  #section-one .first-screen h2,
  #section-one .third-screen h2,
  #section-one .fourth-screen h2,
  #section-one .fifth-screen h2 {
    font-family: var(--font-serif);
    font-size: var(--text-l);
    color: var(--color-black);
  }

  #section-one .fifth-screen h2 {
    margin-bottom: 1.5rem;
  }

  #section-one .first-screen p,
  #section-one .second-screen p,
  #section-one .third-screen p,
  #section-one .fourth-screen p {
    font-family: var(--font-sans);
    font-size: var(--text-m);
    color: var(--color-black);
  }

  #section-one .text-container {
    position: relative;
    z-index: 4;
    display: grid;
    gap: 1rem;
    text-align: center;
    padding: 1rem 0.2rem;
    transform: translateY(-10dvh);
  }

  #section-one .first-screen .text-container {
    width: 50%;
  }
  #section-one .first-screen .text-container:first-child {
    padding-left: 10dvw;
  }
  #section-one .third-screen {
    transform: translateX(135dvw);
  }
  #section-one .fourth-screen {
    transform: translateX(228dvw);
  }
  #section-one .fifth-screen {
    padding-inline: clamp(1rem, 7dvw, 5rem);
    transform: translateX(250dvw);
  }

  #section-one .guidebook-content {
    width: min(100%, 520px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    z-index: 4;
  }

  #section-one .guidebook {
    width: auto;
    max-width: min(80dvw, 400px);
    height: auto;
    object-fit: contain;
    animation: guidebook-float 3.5s ease-in-out infinite;
  }

  #section-one .guidebook-actions {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 0.75rem;
  }

  #section-one .guidebook-button {
    width: 70%;
    border: none;
    border-radius: 8px;
    font-family: var(--font-serif);
    color: var(--color-white);
    font-size: var(--text-m);
    line-height: 1.1;
    cursor: pointer;
    padding: 0.9rem 0.5rem;
    transition: transform 180ms ease;
  }

  #section-one .guidebook-button:hover {
    transform: translateY(-2px);
  }

  #section-one .guidebook-button-guidebook {
    background-color: var(--color-green);
  }

  #section-one .guidebook-button-ticket {
    background-color: var(--color-red-2);
  }
  .paper-texture-1 {
    position: absolute;
    top: 0;
    left: 50%;
    width: 100dvw;
    max-width: none;
    height: 100dvh;
    overflow: hidden;
    pointer-events: none;
    mix-blend-mode: multiply;
    opacity: 0.45;
    filter: contrast(1.15) saturate(0.92);
    aspect-ratio: 1.78 / 1;
    transform: translate(-50%, 0%);
    z-index: 5;
  }
  .seesaw,
  .playground,
  .bouquet-stand,
  .flower-pot-1,
  .flower-pot-2,
  .tree,
  .picnic {
    z-index: 2;
  }
  .grass {
    z-index: 1;
  }
  .seesaw {
    position: absolute;
    left: 8%;
    bottom: 6%;
    width: clamp(174px, 25dvw, 269px);
    height: auto;
  }

  .playground {
    position: absolute;
    left: 0%;
    bottom: 0%;
    height: auto;
    width: clamp(305px, 40dvw, 470px);
    object-fit: contain;
    object-position: center;
  }

  .grass {
    position: absolute;
    left: 0;
    bottom: 0;
    max-width: none;
    width: clamp(2400px, 700dvw, 4900px);
    height: auto;
  }
  .bouquet-stand {
    position: absolute;
    left: 25%;
    bottom: 0%;
    height: auto;
    width: clamp(369px, 55dvw, 631px);
  }
  .flower-pot-1 {
    position: absolute;
    left: 35%;
    bottom: 5%;
    height: auto;
    width: clamp(129px, 20dvw, 200px);
  }

  .flower-pot-2 {
    position: absolute;
    left: 40%;
    bottom: 5%;
    height: auto;
    width: clamp(108px, 20dvw, 200px);
  }

  .tree {
    position: absolute;
    left: 45%;
    bottom: 7%;
    width: clamp(280px, 100dvw, 500px);
    height: auto;
  }

  .picnic {
    position: absolute;
    left: 55%;
    bottom: 5%;
    height: auto;
    width: clamp(300px, 10dvw, 500px);
  }

  @keyframes guidebook-float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-14px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  @media (min-width: 1024px) {
    #section-one {
      --max-horizontal-scroll-vw: 200;
    }
    #section-one .background-container-wrapper {
      width: 275dvw;
    }
    #section-one .first-screen {
      flex-direction: column;
      gap: 0;
    }
    #section-one .first-screen h2,
    #section-one .third-screen h2,
    #section-one .fourth-screen h2 {
      font-size: var(--text-xl);
    }
    #section-one .first-screen p,
    #section-one .second-screen p,
    #section-one .third-screen p,
    #section-one .fourth-screen p {
      font-size: var(--text-m);
    }

    #section-one .guidebook-actions {
      flex-direction: row;
    }

    #section-one .first-screen .text-container:first-child {
      padding: 0;
    }
    #section-one .first-screen {
      justify-content: center;
      align-items: end;
      width: 75dvw;
      transform: translateY(10dvh);
    }
    #section-one .third-screen {
      width: 63dvw;
      transform: translateX(25dvw);
    }
    #section-one .fourth-screen {
      width: 64dvw;
      transform: translateX(40dvw);
    }
    #section-one .fifth-screen {
      padding-inline: clamp(1rem, 7dvw, 5rem);
      transform: translateX(15dvw);
    }

    .seesaw {
      left: 11%;
      bottom: 8%;
    }
    .playground {
      left: 3%;
      bottom: 6%;
    }
    .bouquet-stand {
      left: 30%;
      bottom: 5%;
    }
    .flower-pot-1 {
      left: 42%;
      bottom: 5%;
    }
    .flower-pot-2 {
      left: 46%;
      bottom: 7%;
    }
    .tree {
      left: 56%;
      bottom: 14%;
    }
    .picnic {
      left: 73%;
      bottom: 5%;
    }
  }
</style>

<script>
  (() => {
    const sectionOne = document.getElementById("section-one");
    const horizontalScroll = document.getElementById("horizontal-scroll");

    if (!(sectionOne && horizontalScroll)) {
      return;
    }

    function transform(
      x: number,
      input: number[],
      output: number[],
      easing: (t: number) => number = (t) => t
    ) {
      const firstInput = input[0];
      const lastInput = input.at(-1);
      const lastOutput = output.at(-1);

      if (
        !(
          firstInput !== undefined &&
          lastInput !== undefined &&
          lastOutput !== undefined
        )
      ) {
        return 0;
      }

      const clampedX = Math.max(firstInput, Math.min(lastInput, x));

      for (let i = 0; i < input.length - 1; i++) {
        const currentInput = input[i];
        const nextInput = input[i + 1];

        const currentOutput = output[i];
        const nextOutput = output[i + 1];

        if (
          !(
            currentInput !== undefined &&
            nextInput !== undefined &&
            currentOutput !== undefined &&
            nextOutput !== undefined
          )
        ) {
          continue;
        }

        if (clampedX >= currentInput && clampedX <= nextInput) {
          const localProgress =
            (clampedX - currentInput) / (nextInput - currentInput);
          const easedProgress = easing(localProgress);

          return currentOutput + easedProgress * (nextOutput - currentOutput);
        }
      }

      return lastOutput;
    }

    const easeInOutCubic = (t: number): number => {
      return t < 0.5 ? 4 * t * t * t : 1 - (-2 * t + 2) ** 3 / 2;
    };

    const getMaxHorizontalScrollVw = () => {
      const value = Number.parseFloat(
        getComputedStyle(sectionOne).getPropertyValue(
          "--max-horizontal-scroll-vw"
        )
      );
      return Number.isFinite(value) ? Math.max(value, 0) : 0;
    };

    const updateHorizontalScroll = () => {
      const sectionRect = sectionOne.getBoundingClientRect();
      const sectionHeight = sectionOne.offsetHeight;
      const viewportHeight = window.innerHeight;
      const maxVerticalScroll = sectionHeight - viewportHeight;

      if (maxVerticalScroll <= 0) {
        horizontalScroll.style.setProperty("--translate-x", "0dvw");
        return;
      }

      const scrollProgress = Math.max(
        0,
        Math.min(1, -sectionRect.top / maxVerticalScroll)
      );

      const maxHorizontalScrollVw = getMaxHorizontalScrollVw();
      const horizontalScrollX = transform(
        scrollProgress,
        [0, 1],
        [0, -maxHorizontalScrollVw],
        easeInOutCubic
      );
      horizontalScroll.style.setProperty(
        "--translate-x",
        `${horizontalScrollX}dvw`
      );
    };

    let scrollRafId: number | null = null;
    window.addEventListener(
      "scroll",
      () => {
        if (scrollRafId !== null) {
          return;
        }
        scrollRafId = requestAnimationFrame(() => {
          updateHorizontalScroll();
          scrollRafId = null;
        });
      },
      { passive: true }
    );

    let resizeRafId: number | null = null;
    window.addEventListener("resize", () => {
      if (resizeRafId !== null) {
        cancelAnimationFrame(resizeRafId);
      }
      resizeRafId = requestAnimationFrame(() => {
        updateHorizontalScroll();
        resizeRafId = null;
      });
    });

    updateHorizontalScroll();
  })();
</script>
