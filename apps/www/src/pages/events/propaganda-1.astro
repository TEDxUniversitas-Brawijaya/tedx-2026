  }
  #section-2 .fan-1 {
    position: absolute;
    top: 5%;
    left: 40%;
    width: auto;
    max-width: none;
    height: 20dvh;
    object-fit: contain;
    pointer-events: none;
    aspect-ratio: 2.06 / 1;
  }
  #section-2 .hanging-wardrobe-1 {
    position: absolute;
    bottom: 5%;
    left: 280dvw;
    transform: translate(-300%, 0%);
    width: auto;
    max-width: none;
    height: 55dvh;
    object-fit: contain;
