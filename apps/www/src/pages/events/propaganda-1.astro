    top: 0;
    left: 50%;
    width: 100dvw;
    max-width: none;
    height: 100dvh;
    overflow: hidden;
    pointer-events: none;
    mix-blend-mode: multiply;
    aspect-ratio: 1.78 / 1;
    transform: translate(-50%, 0%);
