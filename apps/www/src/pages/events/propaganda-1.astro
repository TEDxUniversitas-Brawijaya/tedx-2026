    pointer-events: none;
    aspect-ratio: 4.11 / 1;
    mask-image: linear-gradient(to bottom, transparent 0%, black 2%);
    mask-composite: intersect;
  }

  #section-2 .closed-door-skewed {
    position: absolute;
    bottom: -10%;
    left: 280dvw;
    transform: translate(-180%, 0%);
    width: auto;
    height: 90%;
    object-fit: contain;
    pointer-events: none;
    aspect-ratio: 0.25 / 1;
  }
  #section-2 .chandelier-1 {
