---
import PaperTexture1 from "@/assets/imgs/paper-texture-1.png";
import Layout from "@/components/layout.astro";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar.astro";
import { Image } from "astro:assets";
import House1 from "@/assets/imgs/house-1.png";
import GreenRoomBackground2 from "@/assets/imgs/green-room-background-2.png";
import Chandelier1 from "@/assets/imgs/chandelier-1.png";
import ClosedDoorSkewed from "@/assets/imgs/closed-door-skewed.png";
import Sofa2 from "@/assets/imgs/sofa-2.png";
import Table2 from "@/assets/imgs/table-2.png";
import Carpet1 from "@/assets/imgs/carpet-1.png";
import Fan1 from "@/assets/imgs/fan-1.png";
import HangingWardrobe1 from "@/assets/imgs/hanging-wardrobe-1.png";
import Pot1 from "@/assets/imgs/pot-1.png";
import Tree1 from "@/assets/imgs/tree-1.png";
import Leaf1 from "@/assets/imgs/leaf-1.png";
import PastelCoastalLandscape from "@/assets/imgs/pastel-coastal-landscape.png";
import Chair1 from "@/assets/imgs/chair-1.png";
import Table3 from "@/assets/imgs/table-3.png";
import WindowLightShadow1 from "@/assets/imgs/window-light-shadow-1.png";
---

<Layout
  title="Selasar Penerimaan | TEDx Universitas Brawijaya"
  description="Pulang merupakan metafora dari rasa aman yang melampaui batas fisik sebuah bangunan; ia adalah kondisi emosional di mana seseorang merasa diterima seutuhnya, didengar tanpa rasa takut, dan dicintai tanpa ancaman penolakan. Rumah menjadi ruang konsisten yang tidak menggunakan kelemahan sebagai senjata atau membalas kegagalan dengan penghakiman. Di tengah dunia yang semakin cepat dan terfragmentasi, konsep pulang ini kemudian meluas menjadi sebuah kebutuhan untuk merancang teknologi, sistem, dan desain ruang yang mampu menghadirkan kembali ketenangan serta rasa keterhubungan yang menyembuhkan bagi manusia."
  canonical="https://tedxuniversitasbrawijaya.com/events/propaganda-1"
>
  <Navbar />
  <main>
    <section id="section-1">
      <Image
        src={PastelCoastalLandscape}
        alt=""
        class="pastel-coastal-landscape"
      />

      <div class="house-with-trees-container-wrapper">
        <div class="house-with-trees-container">
          <Image src={Tree1} alt="" class="tree-1 tree-1-back" />
          <Image src={Tree1} alt="" class="tree-1 tree-1-front" />
          <Image src={House1} alt="" class="house-1" />
        </div>
      </div>

      <Image src={Leaf1} alt="Leaf 1" class="leaf-1" id="leaf-1" />

      <div class="text-container">
        <h1>Selasar Penerimaan</h1>
        <p>
          Pulang merupakan metafora dari rasa aman yang melampaui batas fisik
          sebuah bangunan; ia adalah kondisi emosional di mana seseorang merasa
          diterima seutuhnya, didengar tanpa rasa takut, dan dicintai tanpa
          ancaman penolakan. Rumah menjadi ruang konsisten yang tidak
          menggunakan kelemahan sebagai senjata atau membalas kegagalan dengan
          penghakiman. Di tengah dunia yang semakin cepat dan terfragmentasi,
          konsep pulang ini kemudian meluas menjadi sebuah kebutuhan untuk
          merancang teknologi, sistem, dan desain ruang yang mampu menghadirkan
          kembali ketenangan serta rasa keterhubungan yang menyembuhkan bagi
          manusia.
        </p>
      </div>

      <div class="gradient"></div>
    </section>
    <section id="section-2">
      <div class="section-2-wrapper">
        <div id="horizontal-scroll" class="horizontal-scroll">
          <div class="background-container-wrapper">
            <div class="background-container">
              <Image
                src={GreenRoomBackground2}
                alt=""
                class="green-room-background-2"
              />
              <Image src={ClosedDoorSkewed} alt="" class="closed-door-skewed" />
              <Image src={Chandelier1} alt="" class="chandelier-1" />
              <Image src={Carpet1} alt="" class="carpet-1" />
              <Image src={Pot1} alt="" class="pot-1" />
              <Image src={Sofa2} alt="" class="sofa-2" />
              <Image src={Table2} alt="" class="table-2" />
              <Image src={Fan1} alt="" class="fan-1" />
              <Image src={HangingWardrobe1} alt="" class="hanging-wardrobe-1" />
              <Image
                src={WindowLightShadow1}
                alt=""
                class="window-light-shadow-1"
              />
            </div>
          </div>

          <div id="first-screen">
            <div class="text-container">
              <h2>Menanggalkan Asing</h2>
              <p>
                Menceritakan tentang momen saat kita sampai di depan pintu rumah
                setelah seharian menghadapi dunia yang melelahkan. Di luar sana,
                kita sering kali terpaksa berpura-pura kuat atau menjadi orang
                lain hanya agar bisa diterima dan dihargai. Begitu sampai di
                rumah, ambang pintu menjadi tempat kita "meletakkan" semua beban
                dan sandiwara itu. Kita tidak lagi perlu memakai topeng; kita
                bisa melepas rasa lelah, berhenti bersikap waspada, dan kembali
                menjadi diri sendiri yang apa adanya—tanpa takut dihakimi atau
                ditolak.
              </p>
            </div>
          </div>
          <div id="second-screen">
            <div class="text-container">
              <h2>Ruang Tumbuh</h2>
              <p>
                Membahas tentang pentingnya rasa aman (secure attachment)
                sebagai fondasi karakter seseorang. Rumah diibaratkan sebagai
                "laboratorium aman" di mana kita pertama kali belajar mencoba,
                melakukan kesalahan, dan mengalami kegagalan. Jika di dalam
                rumah setiap kegagalan kita disambut dengan pelukan, bukan
                kemarahan atau penolakan, maka kita akan tumbuh dengan keyakinan
                bahwa jatuh bukanlah akhir dari segalanya. Rasa aman inilah yang
                nantinya kita bawa ke dunia luar; karena kita tahu ada tempat
                pulang yang selalu menerima, kita pun berubah menjadi pribadi
                yang lebih berani mengambil risiko, lebih tangguh, dan tidak
                takut menghadapi tantangan hidup.
              </p>
            </div>
          </div>

          <div class="outside-container-wrapper">
            <div class="outside-container">
              <Image
                src={PastelCoastalLandscape}
                alt=""
                class="pastel-coastal-landscape"
              />
              <div id="third-screen"></div>
              <div id="fourth-screen">
                <div class="chairs-and-table-container-wrapper">
                  <div class="chairs-and-table-container">
                    <Image src={Chair1} alt="" class="chair-1 left-chair" />
                    <Image src={Table3} alt="" class="table-3" />
                    <Image src={Chair1} alt="" class="chair-1 right-chair" />
                  </div>
                </div>

                <Image src={Tree1} alt="" class="tree-1" />

                <div class="text-container">
                  <h2>Memahat Tenang</h2>
                  <p>
                    Berbicara tentang seni bertahan hidup di tengah dunia modern
                    yang berjalan sangat cepat dan penuh gangguan. Saat ini,
                    kita sering merasa "asing" dan kehilangan arah meski sedang
                    berada di tengah keramaian, karena rasa aman dan ketenangan
                    tidak lagi datang secara otomatis. Oleh karena itu, kita
                    harus secara sadar "memahat" atau membangun sendiri ruang
                    dan kebiasaan yang bisa menghadirkan kembali rasa tenang
                    tersebut. Baik melalui desain ruang yang nyaman, penggunaan
                    teknologi yang bijak, maupun menjaga hubungan yang
                    berkualitas, kita sedang menciptakan sistem perlindungan
                    agar jiwa kita tetap memiliki tempat untuk pulang dan
                    beristirahat di tengah dunia yang kacau.
                  </p>
                </div>
              </div>
            </div>
            <div class="outside-container-overlay"></div>
          </div>
        </div>
        <Image src={PaperTexture1} alt="" class="paper-texture-1" />
      </div>
    </section>
  </main>
  <Footer />
</Layout>
<style>
  main {
    background-color: var(--color-black);
    position: relative;
  }

  #section-1 {
    position: relative;
    height: 100dvh;
    overflow: hidden;
  }

  #section-1 .pastel-coastal-landscape {
    position: absolute;
    top: -10%;
    left: 0%;
    width: 150dvw;
    height: 150dvh;
    max-width: none;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
    aspect-ratio: 1.41 / 1;
  }

  #section-1 .house-with-trees-container-wrapper {
    position: absolute;
    bottom: 50%;
    left: 50%;
    transform: translate(-75%, 125%);
    width: 200dvw;
    height: auto;
  }

  #section-1 .house-with-trees-container {
    position: relative;
    width: 100%;
    height: auto;
    aspect-ratio: 1.5 / 1;
  }

  #section-1 .house-with-trees-container .tree-1 {
    position: absolute;
    width: auto;
    height: 100%;
    object-fit: cover;
    object-position: center;
    aspect-ratio: 0.73 / 1;
  }

  #section-1 .house-with-trees-container .tree-1-back {
    height: 120%;
    top: -15%;
    right: 5%;
  }

  #section-1 .house-with-trees-container .tree-1-front {
    height: 60%;
    right: 7.5%;
    bottom: 20%;
  }

  #section-1 .house-with-trees-container .house-1 {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translate(-50%, 0%) scaleX(-1);
    width: auto;
    height: 100%;
    object-fit: cover;
    object-position: center;
    aspect-ratio: 1.08 / 1;
  }

  #section-1 .leaf-1 {
    position: absolute;
    right: 0%;
    top: 5%;
    width: auto;
    height: 15dvh;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
    aspect-ratio: 0.72 / 1;
    transform: rotate(45deg);
  }

  #section-1 .text-container {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translate(-50%, 0%);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  #section-1 .text-container h1 {
    font-family: var(--font-serif);
    font-size: var(--text-l);
    color: var(--color-black);
  }
  #section-1 .text-container p {
    font-family: var(--font-sans);
    font-size: var(--text-s);
    color: var(--color-black);
    width: 80dvw;
    text-wrap-style: pretty;
  }
  #section-1 .gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, var(--color-green) 0%, transparent 20%);
  }

  #section-2 {
    height: 700dvh;
    position: relative;
  }

  #section-2 .section-2-wrapper {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    background-color: var(--color-green);
