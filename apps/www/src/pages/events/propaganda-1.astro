  }
  #section-2 .outside-container-wrapper {
    position: relative;
    flex-shrink: 0;
    width: 200dvw;
    height: 100dvh;
  }

  #section-2 .outside-container {
    position: relative;
    width: 100%;
    height: 100%;
    aspect-ratio: 0.59 / 1;
    z-index: 1;
    overflow: hidden;
    display: flex;
  }

  #section-2 .outside-container-overlay {
