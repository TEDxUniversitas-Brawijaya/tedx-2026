  #section-2 .background-container-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 280dvw;
    height: 100dvh;
    z-index: 2;
  }

  #section-2 .background-container {
    position: relative;
    width: 100%;
    height: 100%;
    aspect-ratio: 4.11 / 1;
  }

  #section-2 .green-room-background-2 {
