    }

    if (value && typeof value === "object" && "src" in value) {
      const src = (value as { src?: unknown }).src;
      return typeof src === "string" ? src : "";
    }

    return "";
  };
  for (const [assetPath, assetSrc] of Object.entries(coreTeamCardModules)) {
    const fileName = assetPath.split("/").at(-1);
    const resolvedSrc = resolveAssetSrc(assetSrc);

    if (fileName && resolvedSrc) {
      coreTeamCardSrcByFileName[fileName] = resolvedSrc;
    }
  }
  (() => {
    const modalCloseBtn = document.getElementById("modal-close-btn");
    const teamFrameContainer = document.getElementById("team-frame-container");
    const pieceHitboxBtns =
      document.querySelectorAll<HTMLButtonElement>(".piece-hitbox-btn");
    const piecePanelBody = document.getElementById("piece-panel-body");
    const scopeAttrName =
      piecePanelBody
        ?.getAttributeNames()
        .find((name) => name.startsWith("data-astro-cid-")) ?? "";
    const scopeAttr = scopeAttrName ? ` ${scopeAttrName}` : "";
    const familyContent = document.getElementById("family-content");
    const familyDescription = document.getElementById("family-description");
    const defaultFamilyDescription =
      familyDescription?.textContent?.trim() ?? "";
    const volunteerChipSrc =
      piecePanelBody?.getAttribute("data-volunteer-chip-src") ?? "";
    const family = document.getElementById(
      "family"
    ) as HTMLDialogElement | null;
    const createInitials = (name: string) => {
      const words = name
        .trim()
        .split(" ")
        .filter((word) => word.length > 0);
      const initials = words
        .slice(0, 2)
        .map((word) => word.charAt(0).toUpperCase())
        .join("");
      return initials || "TM";
    };
    const sanitize = (value: string) => {
      return value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    };
    if (!(familyContent && piecePanelBody && family && modalCloseBtn)) {
      return;
    }
    const openModal = (roleAttr: string, displayTitle: string) => {
      const teamMembers = JSON.parse(
        piecePanelBody.getAttribute("data-team-members") ?? "[]"
      ) as {
        role: string;
        name: string;
        team: string;
        cardFileNames: { preferred: string };
      }[];
      const normalizedRole = roleAttr.trim();
      const hasExactRoleMatch = teamMembers.some(
        (member: {
          role: string;
          name: string;
          cardFileNames: { preferred: string };
        }) => {
          return member.role === normalizedRole;
        }
      );
      const roles = hasExactRoleMatch
        ? [normalizedRole]
        : normalizedRole
            .split(",")
            .map((r) => r.trim())
            .filter((r) => r.length > 0);
      const members = teamMembers.filter((m: { role: string }) =>
        roles.includes(m.role)
      );
      const coreTeam = members.filter(
        (m: { team: string }) => m.team !== "Volunteer"
      );
      const volunteers = members.filter(
        (m: { team: string }) => m.team === "Volunteer"
      );

      if (familyDescription) {
        familyDescription.textContent = displayTitle;
      }

      const coreCards = coreTeam
        .map(
          (member: { name: string; cardFileNames: { preferred: string } }) => {
            const safeName = sanitize(member.name);
            const initials = sanitize(createInitials(member.name));
            const cardSrc =
              coreTeamCardSrcByFileName[member.cardFileNames.preferred] || "";
            const safeCardSrc = sanitize(cardSrc);
            let cardMarkup: string;
            if (safeCardSrc) {
              cardMarkup = `<img${scopeAttr} class="member-card-photo" src="${safeCardSrc}" alt="${safeName}" aria-hidden="true" />`;
            } else {
              cardMarkup = `<div${scopeAttr} class="member-card-photo member-card-photo-fallback" aria-hidden="true">${initials}</div>`;
            }
            return `<article${scopeAttr} class="member-card">${cardMarkup}</article>`;
          }
        )
        .join("");

      const safeChipSrc = sanitize(volunteerChipSrc);
      const volunteerChips = volunteers
        .map((member: { name: string }) => {
          const safeName = sanitize(member.name);
          return `<article${scopeAttr} class="volunteer-chip"><img${scopeAttr} class="volunteer-chip-bg" src="${safeChipSrc}" alt="" aria-hidden="true" /><p${scopeAttr} class="volunteer-chip-name">${safeName}</p></article>`;
        })
        .join("");

      let html = `<section${scopeAttr}><h2${scopeAttr} class="piece-panel-section-title">Core Team</h2><div${scopeAttr} class="core-team-grid">`;
      html +=
        coreCards ||
        `<article${scopeAttr} class="member-card"><div${scopeAttr} class="member-card-photo" aria-hidden="true">TM</div></article>`;
      html += "</div></section>";

      if (volunteerChips) {
        html += `<section${scopeAttr}><h2${scopeAttr} class="piece-panel-section-title">Volunteer</h2><div${scopeAttr} class="volunteer-chip-wrap">`;
        html += volunteerChips;
        html += "</div></section>";
      }

      piecePanelBody.innerHTML = html;
      family.classList.add("role-active");
      familyContent.classList.add("active");
    };
    const resetFamilyState = () => {
      if (familyDescription) {
        familyDescription.textContent = defaultFamilyDescription;
      }
      family.classList.remove("role-active");
      familyContent?.classList.remove("active");

      if (piecePanelBody) {
        piecePanelBody.innerHTML = "";
      }
    };

    modalCloseBtn?.addEventListener("click", () => {
      resetFamilyState();
      if (family.open) {
        family.close();
      }
    });
    const closeModal = () => {
      resetFamilyState();
      if (family.open) {
        family.close();
      }
    };
    let activeTeamPiece: HTMLButtonElement | null = null;

    for (const pieceHitbox of Array.from(pieceHitboxBtns)) {
      const role = pieceHitbox.dataset.role ?? "";
      const label = pieceHitbox.getAttribute("aria-label") ?? role;

      pieceHitbox.addEventListener("click", () => {
        activeTeamPiece = pieceHitbox;
        openModal(role, label);
      });

      pieceHitbox.addEventListener("keydown", (event: KeyboardEvent) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          activeTeamPiece = pieceHitbox;
          openModal(role, label);
        }
      });
    }

    const getActivePieces = (): HTMLButtonElement[] => {
      const activePieces: HTMLButtonElement[] = [];

      for (const piece of Array.from(pieceHitboxBtns)) {
        if (piece.disabled) {
          continue;
        }

        if (piece.offsetParent === null) {
          continue;
        }

        activePieces.push(piece);
      }

      return activePieces;
    };

    const findFocusedPieceIndex = (activePieces: HTMLButtonElement[]) => {
      const currentFocused = document.activeElement;

      for (let i = 0; i < activePieces.length; i += 1) {
        if (activePieces[i] === currentFocused) {
          return i;
        }
      }

      return -1;
    };

    const getNextPieceIndex = (
      currentIndex: number,
      totalPieces: number,
      isReverse: boolean
    ) => {
      if (isReverse) {
        const reverseIndex = currentIndex - 1;

        if (reverseIndex < 0) {
          return totalPieces - 1;
        }

        return reverseIndex;
      }

      const forwardIndex = currentIndex + 1;

      if (forwardIndex >= totalPieces) {
        return 0;
      }

      return forwardIndex;
    };

    const focusPieceAtIndex = (pieces: HTMLButtonElement[], index: number) => {
      const nextPiece = pieces.at(index);

      if (nextPiece) {
        nextPiece.focus();
      }
    };

    const cycleFocusInActivePieces = (isReverse: boolean) => {
      const activePieces = getActivePieces();

      if (activePieces.length === 0) {
        return;
      }

      const currentIndex = findFocusedPieceIndex(activePieces);

      if (currentIndex === -1) {
        focusPieceAtIndex(activePieces, 0);
        return;
      }

      const nextIndex = getNextPieceIndex(
        currentIndex,
        activePieces.length,
        isReverse
      );

      focusPieceAtIndex(activePieces, nextIndex);
    };

    const isTeamFrameAtScrollMax = () => {
      if (!teamFrameContainer) {
        return false;
      }

      return teamFrameContainer.classList.contains("at-scroll-max");
    };

    const handleGlobalKeydown = (event: KeyboardEvent) => {
      if (!family?.open) {
        return;
      }

      if (event.key === "Escape") {
        event.preventDefault();
        closeModal();
        return;
      }

      if (event.key !== "Tab") {
        return;
      }

      if (family.classList.contains("role-active")) {
        event.preventDefault();
        modalCloseBtn.focus();
        return;
      }

      if (!isTeamFrameAtScrollMax()) {
        return;
      }

      event.preventDefault();
      cycleFocusInActivePieces(event.shiftKey);
    };

    document.addEventListener("keydown", handleGlobalKeydown);
  })();
</script>
