</style>
<script>
  (() => {
    const ourTeamSection = document.getElementById("our-team");
    const tileFloor = document.querySelector(
      ".tile-floor"
    ) as HTMLElement | null;
    const familyFather = document.getElementById("family-father");
    const familyMother = document.getElementById("family-mother");
    const familySister = document.getElementById("family-sister");
    const familyUncle = document.getElementById("family-uncle");
    const familyDaughter = document.getElementById("family-daughter");
    const familyContent = document.getElementById("family-content");
    const family = document.getElementById(
      "family"
    ) as HTMLDialogElement | null;

    const teamFrameWrapper = document.getElementById("team-frame-wrapper");

    const piecePanelBody = document.getElementById("piece-panel-body");

    const modalCloseBtn = document.getElementById("modal-close-btn");
    const familyDescription = document.getElementById("family-description");
    const familyHeader = document.querySelector(
      ".family-header"
    ) as HTMLElement | null;
    const sectionContent = document.querySelector(".section-content");

    const requiredElements =
      familyFather &&
      familyMother &&
      familySister &&
      familyUncle &&
      familyDaughter &&
      family &&
      ourTeamSection &&
      teamFrameWrapper;

    if (!requiredElements) {
      return;
    }

    const familyFatherEl = familyFather as HTMLElement;
    const familyMotherEl = familyMother as HTMLElement;
    const familySisterEl = familySister as HTMLElement;
    const familyUncleEl = familyUncle as HTMLElement;
    const familyDaughterEl = familyDaughter as HTMLElement;
    const ourTeamSectionEl = ourTeamSection as HTMLElement;
    const teamFrameWrapperEl = teamFrameWrapper as HTMLElement;
    const defaultFamilyDescription =
      familyDescription?.textContent?.trim() ?? "";
    const mobileViewportQuery = window.matchMedia("(max-width: 768px)");
    const tabletViewportQuery = window.matchMedia("(max-width: 1024px)");
    let isMobileViewport = mobileViewportQuery.matches;
    let isTabletViewport = tabletViewportQuery.matches;

    const syncViewportFlags = () => {
      isMobileViewport = mobileViewportQuery.matches;
      isTabletViewport = tabletViewportQuery.matches;
    };

    syncViewportFlags();
    window.addEventListener("resize", syncViewportFlags);
    mobileViewportQuery.addEventListener("change", syncViewportFlags);
    tabletViewportQuery.addEventListener("change", syncViewportFlags);
    const DESIGN_WIDTH = 625;
    const MIN_FRAME_SCALE = 0.25;
    const MAX_FRAME_SCALE = 3;
    const HEADER_REVEAL_START = 0.7;
    const SCROLL_MAX_THRESHOLD = 0.99;
    const BASE_FRAME_TRANSLATE = "translate(-50%, -50%)";
    const easeInOutCubic = (t: number): number => {
      return t < 0.5 ? 4 * t * t * t : 1 - (-2 * t + 2) ** 3 / 2;
    };

    function transform(
      x: number,
      input: number[],
      output: number[],
      easing: (t: number) => number = (t) => t
    ) {
      const firstInput = input[0];
      const lastInput = input.at(-1);
      const lastOutput = output.at(-1);

      if (
        !(
          firstInput !== undefined &&
          lastInput !== undefined &&
          lastOutput !== undefined
        )
      ) {
        return 0;
      }

      const clampedX = Math.max(firstInput, Math.min(lastInput, x));

      for (let i = 0; i < input.length - 1; i++) {
        const currentInput = input[i];
        const nextInput = input[i + 1];

        const currentOutput = output[i];
        const nextOutput = output[i + 1];

        if (
          !(
            currentInput !== undefined &&
            nextInput !== undefined &&
            currentOutput !== undefined &&
            nextOutput !== undefined
          )
        ) {
          continue;
        }

        if (clampedX >= currentInput && clampedX <= nextInput) {
          const localProgress =
            (clampedX - currentInput) / (nextInput - currentInput);
          const easedProgress = easing(localProgress);

          return currentOutput + easedProgress * (nextOutput - currentOutput);
        }
      }

      return lastOutput;
    }
    const animateFamily = (scrollProgress: number) => {
      let mobileEntryProgress = 0;

      if (isMobileViewport) {
        mobileEntryProgress = transform(
          scrollProgress,
          [0, 0.3],
          [1, 0],
          easeInOutCubic
        );
      }

      const centerPhaseProgress = transform(
        scrollProgress,
        [0.3, 0.68],
        [0, 1],
        easeInOutCubic
      );

      const exitPhaseProgress = transform(
        scrollProgress,
        [0.68, 1],
        [0, 1],
        easeInOutCubic
      );
      let centerOffsetFactorByMember: {
        father: number;
        mother: number;
        sister: number;
        uncle: number;
        daughter: number;
      };

      if (isMobileViewport) {
        centerOffsetFactorByMember = {
          father: -0.35,
          mother: -0.45,
          sister: -0.2,
          uncle: -0.025,
          daughter: -0.1,
        };
      } else if (isTabletViewport) {
        centerOffsetFactorByMember = {
          father: -0.3,
          mother: -0.4,
          sister: -0.2,
          uncle: -0.1,
          daughter: 0.2,
        };
      } else {
        centerOffsetFactorByMember = {
          father: -0.35,
          mother: -0.34,
          sister: -0.35,
          uncle: -0.35,
          daughter: 0.35,
        };
      }

      const centerOffsetByMember = {
        father: window.innerWidth * centerOffsetFactorByMember.father,
        mother: window.innerWidth * centerOffsetFactorByMember.mother,
        sister: window.innerWidth * centerOffsetFactorByMember.sister,
        uncle: window.innerWidth * centerOffsetFactorByMember.uncle,
        daughter: window.innerWidth * centerOffsetFactorByMember.daughter,
      };

      const directionByMember = {
        father: -1,
        mother: -1,
        sister: 1,
        uncle: 1,
        daughter: -1,
      };

      let outOfBoundsDistanceFactor = 1.5;

      if (isMobileViewport) {
        outOfBoundsDistanceFactor = 1.2;
      } else if (isTabletViewport) {
        outOfBoundsDistanceFactor = 1.35;
      }

      const outOfBoundsDistance = window.innerWidth * outOfBoundsDistanceFactor;

      const moveFamilyMemberToCenter = (
        el: HTMLElement,
        centerOffsetX: number,
        direction: number,
        enterFromRightOnMobile = false
      ) => {
        let mobileEntryOffsetX = 0;

        if (isMobileViewport && enterFromRightOnMobile) {
          mobileEntryOffsetX = window.innerWidth * 0.9 * mobileEntryProgress;
        }

        const centeredDeltaX = centerOffsetX * centerPhaseProgress;
        const finalOutOfBoundsX =
          centerOffsetX + outOfBoundsDistance * direction;
        const deltaX =
          mobileEntryOffsetX +
          centeredDeltaX +
          (finalOutOfBoundsX - centerOffsetX) * exitPhaseProgress;

        el.style.transform = `translate(${Number(deltaX.toFixed(2))}px, 0)`;
      };

      moveFamilyMemberToCenter(
        familyFatherEl,
        centerOffsetByMember.father,
        directionByMember.father,
        true
      );
      moveFamilyMemberToCenter(
        familyMotherEl,
        centerOffsetByMember.mother,
        directionByMember.mother,
        true
      );
      moveFamilyMemberToCenter(
        familyUncleEl,
        centerOffsetByMember.uncle,
        directionByMember.uncle,
        true
      );
      moveFamilyMemberToCenter(
        familySisterEl,
        centerOffsetByMember.sister,
        directionByMember.sister,
        true
      );
      moveFamilyMemberToCenter(
        familyDaughterEl,
        centerOffsetByMember.daughter,
        directionByMember.daughter
      );
    };

    const animateSectionContent = (scrollProgress: number) => {
      if (!sectionContent) {
        return;
      }

      const contentOpacity = transform(
        scrollProgress,
        [0, 0.1, 0.5],
        [1, 1, 0],
        easeInOutCubic
      );

      (sectionContent as HTMLElement).style.opacity = String(contentOpacity);
    };

    const getFrameAnchorX = () => {
      const offsetParent =
        teamFrameWrapperEl.offsetParent as HTMLElement | null;
      const parentLeft = offsetParent?.getBoundingClientRect().left ?? 0;

      return parentLeft + teamFrameWrapperEl.offsetLeft;
    };

    const getCenteredTargetX = () => {
      return window.innerWidth * 0.5 - getFrameAnchorX();
    };

    const getManualFrameScale = () => {
      const rawManualScale = Number.parseFloat(
        window
          .getComputedStyle(teamFrameWrapperEl)
          .getPropertyValue("--team-frame-manual-scale")
      );

      if (!Number.isFinite(rawManualScale)) {
        return 1;
      }

      return Math.min(
        MAX_FRAME_SCALE,
        Math.max(MIN_FRAME_SCALE, rawManualScale)
      );
    };

    const animateTeamFrame = (scrollProgress: number, zoom: number) => {
      let mobileOffsetX: number;
      if (isMobileViewport) {
        mobileOffsetX = -10;
      } else {
        mobileOffsetX = 0;
      }
      const targetX = getCenteredTargetX() + mobileOffsetX;
      let translateX: number;
      if (isMobileViewport) {
        translateX = transform(
          scrollProgress,
          [0, 0.45],
          [targetX + window.innerWidth * 0.75, targetX],
          easeInOutCubic
        );
      } else {
        translateX = transform(
          scrollProgress,
          [0.2, 0.9],
          [0, targetX],
          easeInOutCubic
        );
      }
      let zoomBoost: number;
      if (isTabletViewport) {
        zoomBoost = transform(
          scrollProgress,
          [0.7, 1],
          [1, 1.4],
          easeInOutCubic
        );
      } else {
        zoomBoost = transform(
          scrollProgress,
          [0.7, 1],
          [1, 1.2],
          easeInOutCubic
        );
      }

      let frameDropTargetY: number;
      if (isMobileViewport) {
        frameDropTargetY = 15;
      } else {
        frameDropTargetY = 30;
      }
      const frameDropY = transform(
        scrollProgress,
        [0.7, 1],
        [0, frameDropTargetY],
        easeInOutCubic
      );

      const manualScale = getManualFrameScale();
      const autoScale = teamFrameWrapperEl.clientWidth / DESIGN_WIDTH;
      const rawScale = manualScale * zoom * autoScale * zoomBoost;
      const finalScale = Number.isFinite(rawScale)
        ? Math.min(MAX_FRAME_SCALE, Math.max(MIN_FRAME_SCALE, rawScale))
        : 1;

      const roundedTranslateX = Number(translateX.toFixed(2));
      const roundedFrameTranslateY = Number(frameDropY.toFixed(2));
      const roundedScale = Number(finalScale.toFixed(4));

      teamFrameWrapperEl.style.transform =
        `${BASE_FRAME_TRANSLATE} translateX(${roundedTranslateX}px) translateY(${roundedFrameTranslateY}vh) ` +
        `scale(${roundedScale})`;
    };

    const animateTileFloor = (scrollProgress: number) => {
      if (!tileFloor) {
        return;
      }

      const floorDropY = transform(
        scrollProgress,
        [0.7, 1],
        [0, window.innerHeight * 1.1],
        easeInOutCubic
      );

      tileFloor.style.transform = `translateX(-50%) translateY(${Number(floorDropY.toFixed(2))}px)`;
    };
    const syncTeamFrameZIndex = (scrollProgress: number) => {
      const isAtMaxScroll = scrollProgress >= SCROLL_MAX_THRESHOLD;

      teamFrameWrapperEl.style.zIndex = isAtMaxScroll ? "150" : "";
      teamFrameWrapperEl.classList.toggle("at-scroll-max", isAtMaxScroll);
    };

    const animateFamilyHeader = (scrollProgress: number) => {
      if (!familyHeader) {
        return;
      }
      const headerRevealProgress = transform(
        scrollProgress,
        [HEADER_REVEAL_START, 1],
        [0, 1]
      );

      familyHeader.style.opacity = String(headerRevealProgress);
    };

    const syncFamilyWithScroll = (scrollProgress: number) => {
      if (!family) {
        return;
      }

      const shouldShowPiecePanel = scrollProgress >= HEADER_REVEAL_START;

      const canOpenPiecePanel = shouldShowPiecePanel;
      teamFrameWrapperEl.classList.toggle("hitbox-active", canOpenPiecePanel);

      if (canOpenPiecePanel && !family.open) {
        family.show();
      }

      if (!shouldShowPiecePanel && family.open) {
        resetFamilyState();
        family.close();
      }
    };

    const resetFamilyState = () => {
      if (familyDescription) {
        familyDescription.textContent = defaultFamilyDescription;
      }

      family.classList.remove("role-active");
      modalCloseBtn?.classList.remove("visible");
      familyContent?.classList.remove("active");

      if (piecePanelBody) {
        piecePanelBody.innerHTML = "";
      }
    };

    let smoothProgress = 0;
    let targetProgress = 0;
    let currentZoom = 1;
    let targetZoom = 1;
    const LERP_FACTOR = 0.08;

    const getScrollProgress = () => {
      const sectionRect = ourTeamSectionEl.getBoundingClientRect();
      const sectionHeight = ourTeamSectionEl.offsetHeight;
      const viewportHeight = window.innerHeight;
      return Math.max(
        0,
        Math.min(1, -sectionRect.top / (sectionHeight - viewportHeight))
      );
    };

    const tick = () => {
      targetProgress = getScrollProgress();
      smoothProgress += (targetProgress - smoothProgress) * LERP_FACTOR;
      currentZoom += (targetZoom - currentZoom) * LERP_FACTOR;
      animateTeamFrame(smoothProgress, currentZoom);
      animateFamily(smoothProgress);
      animateSectionContent(smoothProgress);
      syncFamilyWithScroll(targetProgress);
      syncTeamFrameZIndex(targetProgress);
      animateFamilyHeader(targetProgress);
      animateTileFloor(targetProgress);
      requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  })();
  const coreTeamCardModules = import.meta.glob(
    "../assets/imgs/core-team-cards/*.png",
    {
      eager: true,
      import: "default",
    }
  ) as Record<string, unknown>;
  const coreTeamCardSrcByFileName: Record<string, string> = {};

  const resolveAssetSrc = (value: unknown) => {
    if (typeof value === "string") {
      return value;
    }

    if (value && typeof value === "object" && "src" in value) {
      const src = (value as { src?: unknown }).src;
      return typeof src === "string" ? src : "";
    }

    return "";
  };
  for (const [assetPath, assetSrc] of Object.entries(coreTeamCardModules)) {
    const fileName = assetPath.split("/").at(-1);
    const resolvedSrc = resolveAssetSrc(assetSrc);

    if (fileName && resolvedSrc) {
      coreTeamCardSrcByFileName[fileName] = resolvedSrc;
    }
  }
  (() => {
    const modalCloseBtn = document.getElementById("modal-close-btn");
    const teamFrameWrapper = document.getElementById("team-frame-wrapper");
    const pieceHitboxBtns =
      document.querySelectorAll<HTMLButtonElement>(".piece-hitbox-btn");
    const piecePanelBody = document.getElementById("piece-panel-body");
    const scopeAttrName =
      piecePanelBody
        ?.getAttributeNames()
        .find((name) => name.startsWith("data-astro-cid-")) ?? "";
    const scopeAttr = scopeAttrName ? ` ${scopeAttrName}` : "";
    const familyContent = document.getElementById("family-content");
    const familyDescription = document.getElementById("family-description");
    const defaultFamilyDescription =
      familyDescription?.textContent?.trim() ?? "";
    const volunteerChipSrc =
      piecePanelBody?.getAttribute("data-volunteer-chip-src") ?? "";
    const family = document.getElementById(
      "family"
    ) as HTMLDialogElement | null;
    const createInitials = (name: string) => {
      const words = name
        .trim()
        .split(" ")
        .filter((word) => word.length > 0);
      const initials = words
        .slice(0, 2)
        .map((word) => word.charAt(0).toUpperCase())
        .join("");
      return initials || "TM";
    };
    const sanitize = (value: string) => {
      return value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    };
    if (!(familyContent && piecePanelBody && family && modalCloseBtn)) {
      return;
    }
    const openModal = (roleAttr: string, displayTitle: string) => {
      const teamMembers = JSON.parse(
        piecePanelBody.getAttribute("data-team-members") ?? "[]"
      ) as {
        role: string;
        name: string;
        team: string;
        cardFileNames: { preferred: string };
      }[];
      const normalizedRole = roleAttr.trim();
      const hasExactRoleMatch = teamMembers.some(
        (member: {
          role: string;
          name: string;
          cardFileNames: { preferred: string };
        }) => {
          return member.role === normalizedRole;
        }
      );
      const roles = hasExactRoleMatch
        ? [normalizedRole]
        : normalizedRole
            .split(",")
            .map((r) => r.trim())
            .filter((r) => r.length > 0);
      const members = teamMembers.filter((m: { role: string }) =>
        roles.includes(m.role)
      );
      const coreTeam = members.filter(
        (m: { team: string }) => m.team !== "Volunteer"
      );
      const volunteers = members.filter(
        (m: { team: string }) => m.team === "Volunteer"
      );

      if (familyDescription) {
        familyDescription.textContent = displayTitle;
      }

      const coreCards = coreTeam
        .map(
          (member: { name: string; cardFileNames: { preferred: string } }) => {
            const safeName = sanitize(member.name);
            const initials = sanitize(createInitials(member.name));
            const cardSrc =
              coreTeamCardSrcByFileName[member.cardFileNames.preferred] || "";
            const safeCardSrc = sanitize(cardSrc);
            let cardMarkup: string;
            if (safeCardSrc) {
              cardMarkup = `<img${scopeAttr} class="member-card-photo" src="${safeCardSrc}" alt="${safeName}" aria-hidden="true" />`;
            } else {
              cardMarkup = `<div${scopeAttr} class="member-card-photo member-card-photo-fallback" aria-hidden="true">${initials}</div>`;
            }
            return `<article${scopeAttr} class="member-card">${cardMarkup}</article>`;
          }
        )
        .join("");

      const safeChipSrc = sanitize(volunteerChipSrc);
      const volunteerChips = volunteers
        .map((member: { name: string }) => {
          const safeName = sanitize(member.name);
          return `
          <article${scopeAttr} class="volunteer-chip">
            <img${scopeAttr} class="volunteer-chip-bg" src="${safeChipSrc}" alt="" aria-hidden="true" />
            <div${scopeAttr} class="volunteer-chip-white-bg" ></div>
            <p${scopeAttr} class="volunteer-chip-name">${safeName}</p>
          </article>
              `;
        })
        .join("");

      let html = `<section${scopeAttr}><h2${scopeAttr} class="piece-panel-section-title">Core Team</h2><div${scopeAttr} class="core-team-grid">`;
      html +=
        coreCards ||
        `<article${scopeAttr} class="member-card"><div${scopeAttr} class="member-card-photo" aria-hidden="true">TM</div></article>`;
      html += "</div></section>";

      if (volunteerChips) {
        html += `<section${scopeAttr}>
          <h2${scopeAttr} class="piece-panel-section-title">Volunteer</h2><div${scopeAttr} class="volunteer-chip-wrap">`;
        html += volunteerChips;
        html += "</div></section>";
      }

      piecePanelBody.innerHTML = html;
      family.classList.add("role-active");
      familyContent.classList.add("active");
    };
    const resetFamilyState = () => {
      if (familyDescription) {
        familyDescription.textContent = defaultFamilyDescription;
      }
      family.classList.remove("role-active");
      familyContent?.classList.remove("active");

      if (piecePanelBody) {
        piecePanelBody.innerHTML = "";
      }
    };

    modalCloseBtn?.addEventListener("click", () => {
      resetFamilyState();
      if (family.open) {
        family.close();
      }
    });
    const closeModal = () => {
      resetFamilyState();
      if (family.open) {
        family.close();
      }
    };
    let activeTeamPiece: HTMLButtonElement | null = null;

    for (const pieceHitbox of Array.from(pieceHitboxBtns)) {
      const role = pieceHitbox.dataset.role ?? "";
      const label = pieceHitbox.getAttribute("aria-label") ?? role;

      pieceHitbox.addEventListener("click", () => {
        activeTeamPiece = pieceHitbox;
        openModal(role, label);
      });

      pieceHitbox.addEventListener("keydown", (event: KeyboardEvent) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          activeTeamPiece = pieceHitbox;
          openModal(role, label);
        }
      });
    }

    const getActivePieces = (): HTMLButtonElement[] => {
      const activePieces: HTMLButtonElement[] = [];

      for (const piece of Array.from(pieceHitboxBtns)) {
        if (piece.disabled) {
          continue;
        }

        if (piece.offsetParent === null) {
          continue;
        }

        activePieces.push(piece);
      }

      return activePieces;
    };

    const findFocusedPieceIndex = (activePieces: HTMLButtonElement[]) => {
      const currentFocused = document.activeElement;

      for (let i = 0; i < activePieces.length; i += 1) {
        if (activePieces[i] === currentFocused) {
          return i;
        }
      }

      return -1;
    };

    const getNextPieceIndex = (
      currentIndex: number,
      totalPieces: number,
      isReverse: boolean
    ) => {
      if (isReverse) {
        const reverseIndex = currentIndex - 1;

        if (reverseIndex < 0) {
          return totalPieces - 1;
        }

        return reverseIndex;
      }

      const forwardIndex = currentIndex + 1;

      if (forwardIndex >= totalPieces) {
        return 0;
      }

      return forwardIndex;
    };

    const focusPieceAtIndex = (pieces: HTMLButtonElement[], index: number) => {
      const nextPiece = pieces.at(index);

      if (nextPiece) {
        nextPiece.focus();
      }
    };

    const cycleFocusInActivePieces = (isReverse: boolean) => {
      const activePieces = getActivePieces();

      if (activePieces.length === 0) {
        return;
      }

      const currentIndex = findFocusedPieceIndex(activePieces);

      if (currentIndex === -1) {
        focusPieceAtIndex(activePieces, 0);
        return;
      }

      const nextIndex = getNextPieceIndex(
        currentIndex,
        activePieces.length,
        isReverse
      );

      focusPieceAtIndex(activePieces, nextIndex);
    };

    const isTeamFrameAtScrollMax = () => {
      if (!teamFrameWrapper) {
        return false;
      }

      return teamFrameWrapper.classList.contains("at-scroll-max");
    };

    const handleGlobalKeydown = (event: KeyboardEvent) => {
      if (!family?.open) {
        return;
      }

      if (event.key === "Escape") {
        event.preventDefault();
        closeModal();
        return;
      }

      if (event.key !== "Tab") {
        return;
      }

      if (family.classList.contains("role-active")) {
        event.preventDefault();
        modalCloseBtn.focus();
        return;
      }

      if (!isTeamFrameAtScrollMax()) {
        return;
      }

      event.preventDefault();
      cycleFocusInActivePieces(event.shiftKey);
    };

    document.addEventListener("keydown", handleGlobalKeydown);
  })();
</script>
