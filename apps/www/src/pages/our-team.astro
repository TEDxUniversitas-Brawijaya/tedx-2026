      { role: "Website", name: "Hafiz Rizky", team: "Core Team" },
      { role: "Website", name: "Nugraha Billy", team: "Core Team" },
      { role: "Website", name: "Alfredo Radhinal", team: "Core Team" },
      { role: "Website", name: "Rahmi Arsy", team: "Volunteer" },
      { role: "Website", name: "Exel Boy", team: "Volunteer" },
      { role: "Website", name: "Risqi Achmad", team: "Volunteer" },
      { role: "Website", name: "Muhammad Syauqi", team: "Volunteer" },
    ];

    const showPiecePanel = (roleAttr: string, displayTitle: string) => {
      if (!(familyModalContent && piecePanelTitle && piecePanelBody)) {
        return;
      }

      const roles = roleAttr.split(",").map((r) => r.trim());
      const members = teamMembers.filter((m) => roles.includes(m.role));

      piecePanelTitle.textContent = displayTitle;

      const coreTeam = members.filter((m) => m.team === "Core Team");
      const volunteers = members.filter((m) => m.team === "Volunteer");
      const noTeam = members.filter((m) => !m.team);

      let html = "";
      if (noTeam.length > 0) {
        html += '<div class="piece-panel-group">';
        for (const m of noTeam) {
          html += `<p class="piece-panel-member">${m.name}</p>`;
        }
        html += "</div>";
      }
      if (coreTeam.length > 0) {
        html +=
          '<div class="piece-panel-group"><p class="piece-panel-group-label">Core Team</p>';
        for (const m of coreTeam) {
          html += `<p class="piece-panel-member">${m.name}</p>`;
        }
        html += "</div>";
      }
      if (volunteers.length > 0) {
        html +=
          '<div class="piece-panel-group"><p class="piece-panel-group-label">Volunteer</p>';
        for (const m of volunteers) {
          html += `<p class="piece-panel-member">${m.name}</p>`;
        }
        html += "</div>";
      }

      piecePanelBody.innerHTML = html;
      familyModalContent.classList.add("active");
    };

    const pieceHitboxBtns =
      document.querySelectorAll<HTMLButtonElement>(".piece-hitbox-btn");
    for (const btn of Array.from(pieceHitboxBtns)) {
      btn.addEventListener("click", (e: Event) => {
        e.stopPropagation();
        if (!modal?.open) {
          return;
        }

        const role = btn.dataset.role;
        const label = btn.getAttribute("aria-label") ?? role ?? "";
        if (role) {
          showPiecePanel(role, label);
        }
      });
    }

    piecePanelClose?.addEventListener("click", (e) => {
      e.stopPropagation();
      if (familyModalContent) {
        familyModalContent.classList.remove("active");
      }
    });

    modalCloseBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      closeModal();
    });
  })();
</script>
