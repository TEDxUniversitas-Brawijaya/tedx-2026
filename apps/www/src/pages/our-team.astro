      const isAtMaxScroll = scrollProgress >= SCROLL_MAX_THRESHOLD;

      teamFrameContainerEl.style.zIndex = isAtMaxScroll ? "150" : "";
      teamFrameContainerEl.classList.toggle("at-scroll-max", isAtMaxScroll);
    };

    const animateFamilyHeader = (scrollProgress: number) => {
      if (!familyHeader) {
        return;
      }
      const headerRevealProgress = transform(
        scrollProgress,
        [HEADER_REVEAL_START, 1],
        [0, 1]
