---

<Layout
  title="Meet Our Team | TEDx Universitas Brawijaya"
  description="Inilah insan-insan di balik TEDxUniversitasBrawijaya 2026. Bukan sekadar tim, melainkan sebuah keluarga yang Bertumbuh Bersama demi membangun rumah bagi setiap ide yang layak diperjuangkan."
>
  <NavBar />
  <main>
    <section id="our-team">
      <div class="our-team-wrapper">
        <Image src={PaperTexture} alt={"Paper Texture"} class="paper-texture" />
        <Image
          src={GreenBackground}
          alt={"Green Background"}
          class="green-background"
        />

        <Image src={TileFloor} alt={"Tile Floor"} class="tile-floor" />
        <div class="team-frame-container" id="team-frame-container">
          <svg
            class="team-frame-outline"
            width="625"
            height="378"
            viewBox="0 0 625 379"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect
              x="7.07089"
              y="7.06992"
              width="609.732"
              height="364.141"
              stroke="currentColor"
              stroke-width="14.1414"
            />
          </svg>
          <Image
            src={TeamFrameBackground}
            id={"team-frame-background"}
            class="team-frame-background team-layer"
            alt={"Team Frame Background"}
          />
          <Image
            src={EventManagerPiece}
            id={"event-manager-piece"}
            class="team-piece"
            alt={"Event Manager Piece"}
          />
          <Image
            src={CemPiece}
            id={"cem-piece"}
            class="team-piece"
            alt={"Content & Events Manager Piece"}
          />
          <Image
            src={BudgetPiece}
            id={"budget-piece"}
            class="team-piece"
            alt={"Budget Piece"}
          />
          <Image
            src={CuratorPiece}
            id={"curator-piece"}
            class="team-piece"
            alt={"Curator Piece"}
          />
          <Image
            src={EpPiece}
            id={"ep-piece"}
            class="team-piece"
            alt={"Events Producer Piece"}
          />
          <Image
            src={OrganizerPiece}
            id={"organizer-piece"}
            class="team-piece"
            alt={"Organizer Piece"}
          />
          <Image
            src={DesignPiece}
            id={"design-piece"}
            class="team-piece"
            alt={"Design Piece"}
          />
          <Image
            src={SponsorshipPiece}
            id={"sponsorship-piece"}
            class="team-piece"
            alt={"Sponsorship Piece"}
          />
          <Image
            src={VpPiece}
            id={"vp-piece"}
            class="team-piece"
            alt={"Vice President Piece"}
          />
          <Image
            src={WebsitePiece}
            id={"website-piece"}
            class="team-piece"
            alt={"Website Piece"}
          />
          <div class="piece-hitbox-layer">
            <button
              class="piece-hitbox-btn piece-hitbox-event-manager"
              aria-label="Event Manager"
              data-role="Event Manager"
              tabindex="0"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-cem"
              aria-label="Communication, Editorial & Marketing"
              data-role="Communication, Editorial & Marketing"
              tabindex="0"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-budget"
              aria-label="Budget Manager"
              data-role="Budget Manager"
              tabindex="0"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-curator"
              aria-label="Curator"
              data-role="Curator"
              tabindex="0"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-ep"
              aria-label="Executive Producer"
              data-role="Executive Producer"
              tabindex="0"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-organizer"
              aria-label="Organizer"
              data-role="Organizer,Co-Organizer"
              tabindex="0"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-design"
              aria-label="Design"
              data-role="Design"
              tabindex="0"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-sponsorship"
              aria-label="Sponsorship"
              data-role="Sponsorship"
              tabindex="0"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-vp"
              aria-label="Video Production"
              data-role="Video Production"
              tabindex="0"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-website"
              aria-label="Website"
              data-role="Website"
              tabindex="0"
            ></button>
          </div>
          <Image
            src={EmptyPieceTop}
            id={"empty-piece-top"}
            class="team-empty-piece"
            alt={"Empty Piece Top"}
          />
          <Image
            src={EmptyPieceBottom}
            id={"empty-piece-bottom"}
            class="team-empty-piece"
            alt={"Empty Piece Bottom"}
          />
          <Image
            src={EmptyPieceTopRight}
            id={"empty-piece-top-right"}
            class="team-empty-piece"
            alt={"Empty Piece Top Right"}
          />
        </div>
        <div
          class="family-container"
          id="family-container"
          aria-label="Klik untuk melihat keluarga kami"
        >
          <Image
            src={Father}
            alt="Father"
            class="family-father"
            id="family-father"
            aria-hidden="true"
          />
          <Image
            src={Mother}
            alt="Mother"
            class="family-mother"
            id="family-mother"
            aria-hidden="true"
          />
          <Image
            src={Sister}
            alt="Sister"
            class="family-sister"
            id="family-sister"
            aria-hidden="true"
          />
          <Image
            src={Uncle}
            alt="Uncle"
            class="family-uncle"
            id="family-uncle"
            aria-hidden="true"
          />
          <Image
            src={Daughter}
            alt="Daughter"
            class="family-daughter"
            id="family-daughter"
            aria-hidden="true"
          />
        </div>
        <div class="section-content">
          <h2>DIBALIK KELUARGA TEDX Universitas Brawijaya</h2>
          <p>
            Inilah insan-insan di balik TEDxUniversitasBrawijaya 2026. Bukan
            sekadar tim, melainkan sebuah keluarga yang Bertumbuh Bersama demi
            membangun rumah bagi setiap ide yang layak diperjuangkan.
          </p>
        </div>
      </div>
    </section>
    <dialog id="family" class="family">
      <div class="family-topbar">
        <div class="family-header">
          <h2 class="family-heading">Meet the Team</h2>
          <p class="family-description" id="family-description">
            Setiap divisi memiliki peran penting dalam menghadirkan
            TEDxUniversitasBrawijaya. Klik divisi untuk melihat tim di baliknya.
          </p>
        </div>
        <div class="modal-close-layout">
          <button
            class="modal-close-btn"
            id="modal-close-btn"
            type="button"
            aria-label="Tutup modal"
          >
            <svg
              class="modal-close-icon"
              width="40"
              height="40"
              viewBox="0 0 40 40"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M20.0003 22.3327L11.8337 30.4993C11.5281 30.8049 11.1392 30.9577 10.667 30.9577C10.1948 30.9577 9.80588 30.8049 9.50032 30.4993C9.19477 30.1938 9.04199 29.8049 9.04199 29.3327C9.04199 28.8605 9.19477 28.4716 9.50032 28.166L17.667 19.9993L9.50032 11.8327C9.19477 11.5271 9.04199 11.1382 9.04199 10.666C9.04199 10.1938 9.19477 9.8049 9.50032 9.49935C9.80588 9.19379 10.1948 9.04102 10.667 9.04102C11.1392 9.04102 11.5281 9.19379 11.8337 9.49935L20.0003 17.666L28.167 9.49935C28.4725 9.19379 28.8614 9.04102 29.3337 9.04102C29.8059 9.04102 30.1948 9.19379 30.5003 9.49935C30.8059 9.8049 30.9587 10.1938 30.9587 10.666C30.9587 11.1382 30.8059 11.5271 30.5003 11.8327L22.3337 19.9993L30.5003 28.166C30.8059 28.4716 30.9587 28.8605 30.9587 29.3327C30.9587 29.8049 30.8059 30.1938 30.5003 30.4993C30.1948 30.8049 29.8059 30.9577 29.3337 30.9577C28.8614 30.9577 28.4725 30.8049 28.167 30.4993L20.0003 22.3327Z"
                fill="#F8F1DC"
              />
            </svg>
          </button>
        </div>
      </div>
      <Image src={Line} alt="Line" id="family-line" class="family-line" />

      <div class="family-content" id="family-content">
        <div class="piece-panel-separator" aria-hidden="true"></div>
        <div
          class="piece-panel-body"
          id="piece-panel-body"
          data-team-members={JSON.stringify(teamMembers)}
          data-volunteer-chip-src={VolunteerChip.src}
        ></div>
      </div>
    </dialog>
  </main>
</Layout>
<style>
  #our-team {
    position: relative;
    height: 560dvh;
  }

  .our-team-wrapper {
    position: sticky;
    inset: 0;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    isolation: isolate;
  }

  .green-background,
  .paper-texture {
    position: absolute;
    inset: 0;
    width: 102%;
    height: 102%;
    object-fit: cover;
    pointer-events: none;
  }

  .paper-texture {
    mix-blend-mode: multiply;
    z-index: 150;
  }

  .tile-floor {
    position: absolute;
    left: 50%;
    bottom: -2%;
    width: min(200rem, 200vw);
    height: clamp(5rem, 20vh, 40rem);
    aspect-ratio: 16 / 5;
    transform: translateX(-50%);
    object-fit: cover;
    pointer-events: none;
    will-change: transform;
  }

  .team-frame-container {
    position: absolute;
    top: 35%;
    left: 85%;
    width: clamp(40rem, 30vw, 45rem);
    aspect-ratio: 1 / 1;
    pointer-events: auto;
    transform-origin: center;
    will-change: transform;
  }

  .team-frame-outline {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-red);
    pointer-events: none;
    z-index: 95;
  }

  .team-frame-outline rect {
    stroke: var(--color-red);
  }

  .team-frame-container img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    pointer-events: none;
  }

  .team-layer,
  .team-piece,
  .team-empty-piece {
    transform: translateZ(0) scale(0.95);
    backface-visibility: hidden;
    will-change: transform;
  }

  #team-frame-background {
    z-index: 90;
  }

  .team-piece,
  .team-empty-piece {
    z-index: 100;
    pointer-events: none;
  }

  .piece-hitbox-layer {
    position: absolute;
    inset: 2.5%;
    pointer-events: none;
    z-index: 130;
  }

  .piece-hitbox-btn {
    position: absolute;
    top: var(--hitbox-y, 50%);
    left: var(--hitbox-x, 50%);
    width: var(--hitbox-w, 10%);
    height: var(--hitbox-h, 10%);
    transform: translate(-50%, -50%);
    padding: 0;
    pointer-events: none;
    cursor: pointer;
    opacity: 0;
  }

  .team-frame-container.hitbox-active .piece-hitbox-btn {
    pointer-events: auto;
  }

  .piece-hitbox-event-manager {
    --hitbox-x: 33%;
    --hitbox-y: 28%;
    --hitbox-w: 24%;
    --hitbox-h: 15%;
  }

  .piece-hitbox-cem {
    --hitbox-x: 47%;
    --hitbox-y: 50%;
    --hitbox-w: 15%;
    --hitbox-h: 15%;
  }

  .piece-hitbox-budget {
    --hitbox-x: 46%;
    --hitbox-y: 75%;
    --hitbox-w: 35%;
    --hitbox-h: 10%;
  }

  .piece-hitbox-curator {
    --hitbox-x: 30%;
    --hitbox-y: 45%;
    --hitbox-w: 10%;
    --hitbox-h: 15%;
  }

  .piece-hitbox-ep {
    --hitbox-x: 10%;
    --hitbox-y: 30%;
    --hitbox-w: 15%;
    --hitbox-h: 15%;
  }

  .piece-hitbox-organizer {
    --hitbox-x: 10%;
    --hitbox-y: 60%;
    --hitbox-w: 20%;
    --hitbox-h: 35%;
  }

  .piece-hitbox-design {
    --hitbox-x: 80.5%;
    --hitbox-y: 70.5%;
    --hitbox-w: 15%;
    --hitbox-h: 20%;
  }

  .piece-hitbox-sponsorship {
    --hitbox-x: 80%;
    --hitbox-y: 40%;
    --hitbox-w: 20%;
    --hitbox-h: 20%;
  }

  .piece-hitbox-vp {
    --hitbox-x: 65%;
    --hitbox-y: 60%;
    --hitbox-w: 10%;
    --hitbox-h: 10%;
  }

  .piece-hitbox-website {
    --hitbox-x: 95%;
    --hitbox-y: 65%;
    --hitbox-w: 10%;
    --hitbox-h: 30%;
  }

  .team-frame-container.hitbox-active:has(
      .piece-hitbox-event-manager:is(:hover, :focus-visible)
    )
    #event-manager-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-cem:is(:hover, :focus-visible)
    )
    #cem-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-budget:is(:hover, :focus-visible)
    )
    #budget-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-curator:is(:hover, :focus-visible)
    )
    #curator-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-ep:is(:hover, :focus-visible)
    )
    #ep-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-organizer:is(:hover, :focus-visible)
    )
    #organizer-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-design:is(:hover, :focus-visible)
    )
    #design-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-sponsorship:is(:hover, :focus-visible)
    )
    #sponsorship-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-vp:is(:hover, :focus-visible)
    )
    #vp-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-website:is(:hover, :focus-visible)
    )
    #website-piece {
    filter: brightness(1.4) drop-shadow(0px 4px 25px rgba(255, 149, 0, 0.5));
  }

  .family-container {
    /* Desktop placeholders: adjust these values freely */
    --family-father-left: auto;
    --family-father-right: 10vw;
    --family-father-top: 50vh;

    --family-mother-left: auto;
    --family-mother-right: 24vw;
    --family-mother-top: 65vh;

    --family-sister-left: auto;
    --family-sister-right: 0vw;
    --family-sister-top: 60vh;

    --family-uncle-left: auto;
    --family-uncle-right: -5vw;
    --family-uncle-top: 50vh;

    --family-daughter-left: 0%;
    --family-daughter-right: auto;
    --family-daughter-top: 80vh;

    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 10;
    opacity: 1;
    transition: opacity 0.15s ease;
    will-change: opacity;
