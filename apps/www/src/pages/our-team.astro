      { role: "Event Manager", name: "Ajeng Regina", team: "Core Team" },
      { role: "Event Manager", name: "Fazqeela Nazyyara", team: "Core Team" },
      { role: "Event Manager", name: "Zeke Ubas", team: "Core Team" },
      { role: "Event Manager", name: "Katyusha Parikesit", team: "Volunteer" },
