      const centerProgress = transform(
        scrollProgress,
        [0.5, 0.8],
        [0, 1],
        easeInOutCubic
      );

      const centerOffsetByMember = {
        father: window.innerWidth * (isMobileViewport ? -0.15 : isTabletViewport ? -0.3 : -0.35),
        mother: window.innerWidth * (isMobileViewport ? -0.3 : isTabletViewport ? -0.4 : -0.35),
        sister: window.innerWidth * (isMobileViewport ? -0.1  : isTabletViewport ? -0.25 : -0.35),
        uncle: window.innerWidth * (isMobileViewport ? 0.1 : isTabletViewport ? -0.15 : -0.35),
        daughter: window.innerWidth * (isMobileViewport ? 0.1 : isTabletViewport ? 0.23 : 0.2),
      };

      const moveTowardTargetX = (el: HTMLElement, centerOffsetX: number) => {
        const centeredDeltaX = centerOffsetX * centerProgress;
        const deltaX = Number(centeredDeltaX.toFixed(2));

        el.style.transform = `translate(${deltaX}px, 0)`;
      };

      moveTowardTargetX(familyFatherEl, centerOffsetByMember.father);
      moveTowardTargetX(familyMotherEl, centerOffsetByMember.mother);
      moveTowardTargetX(familyUncleEl, centerOffsetByMember.uncle);
      moveTowardTargetX(familySisterEl, centerOffsetByMember.sister);
      moveTowardTargetX(familyDaughterEl, centerOffsetByMember.daughter);

      familyFatherEl.style.opacity = String(familyFatherOpacity);
      familyMotherEl.style.opacity = String(familyMotherOpacity);
      familyUncleEl.style.opacity = String(familyUncleOpacity);
      familySisterEl.style.opacity = String(familySisterOpacity);
      familyDaughterEl.style.opacity = String(familyDaughterOpacity);
    };


    const animateSectionContent = (scrollProgress: number) => {
      if (!sectionContent) {
        return;
      }

      const contentOpacity = transform(
        scrollProgress,
        [0, 0.1, 0.5],
        [1, 1, 0],
        easeInOutCubic
      );

      (sectionContent as HTMLElement).style.opacity = String(contentOpacity);
    };


    const getCenteredTargetX = () => {
      const leftAnchor = Number.parseFloat(
        window.getComputedStyle(teamFrameContainerEl).left
      );

      if (Number.isNaN(leftAnchor)) {
        return 0;
      }

      return window.innerWidth * 0.5 - leftAnchor;
    };

    const animateTeamFrame = (scrollProgress: number, zoom: number) => {
      const targetX = getCenteredTargetX();
      const translateX = isMobileViewport
        ? transform(
            scrollProgress,
            [0, 0.45],
            [targetX + window.innerWidth * 0.75, targetX],
            easeInOutCubic
          )
        : transform(scrollProgress, [0.2, 0.9], [0, targetX], easeInOutCubic);

      const autoScale = teamFrameContainerEl.clientWidth / DESIGN_WIDTH;
      const finalScale = zoom * autoScale;

      teamFrameContainerEl.style.transform =
        `${BASE_FRAME_TRANSLATE} translateX(${translateX}px) translateY(${frameTranslateY}vh) ` +
        `scale(${finalScale})`;
    };
    let modalOpenTime = 0;
    const MODAL_EXIT_DELAY = 1000; // ms before animations start
    const MODAL_EXIT_DURATION = 700; // ms for the animation itself
    const MODAL_HITBOX_READY_TIME = MODAL_EXIT_DELAY + MODAL_EXIT_DURATION;

    const animateModalTransition = () => {
      if (!modal?.open) {
        return;
      }

      const elapsed = performance.now() - modalOpenTime;
      const t = Math.max(
        0,
        Math.min(1, (elapsed - MODAL_EXIT_DELAY) / MODAL_EXIT_DURATION)
      );
      const eased = easeInOutCubic(t);

      if (elapsed >= MODAL_HITBOX_READY_TIME) {
        teamFrameContainerEl.classList.add("hitbox-active");
      } else {
        teamFrameContainerEl.classList.remove("hitbox-active");
      }

      // Zoom up and slide down slightly after delay
      targetZoom = MODAL_ZOOM + (MODAL_ZOOM_POST_DELAY - MODAL_ZOOM) * eased;
      frameTranslateY = eased * 20;

      if (tileFloor) {
        tileFloor.style.transform = `translateX(-50%) translateY(${eased * 120}%)`;
      }

      const centerProgress = transform(
        smoothProgress,
        [0.5, 0.8],
        [0, 1],
        easeInOutCubic
      );

      const centerOffsetByMember = {
        father: window.innerWidth * (isMobileViewport ? -0.08 : -0.35),
        mother: window.innerWidth * (isMobileViewport ? -0.04 : -0.35),
        sister: window.innerWidth * (isMobileViewport ? 0.03 : -0.35),
        uncle: window.innerWidth * (isMobileViewport ? 0.08 : -0.35),
        daughter: window.innerWidth * (isMobileViewport ? 0.01 : 0.3),
      };

      const sideDirectionByMember = {
        father: -1,
        mother: -1,
        sister: 1,
        uncle: 1,
        daughter: -1,
      };

      const FAMILY_TO_SIDE_DURATION = 150;
      const FAMILY_SIDE_HOLD_DELAY = 950  ;
      const FAMILY_TO_OUT_DURATION = 800;

      const sidePhaseProgress = Math.max(
        0,
        Math.min(1, elapsed / FAMILY_TO_SIDE_DURATION)
      );
      const outPhaseProgress = Math.max(
        0,
        Math.min(
          1,
          (elapsed - FAMILY_TO_SIDE_DURATION - FAMILY_SIDE_HOLD_DELAY) /
            FAMILY_TO_OUT_DURATION
        )
      );

      const sideTravel = window.innerWidth * (isMobileViewport ? 0.24 : 0.32);
      const outTravel = window.innerWidth * (isMobileViewport ? 1.05 : 1.25);
      const outTravelY = isTabletViewport
        ? window.innerHeight * (isMobileViewport ? 1.15 : 1.05)
        : 0;

      const applyModalFamilyTransform = (
        el: HTMLElement,
        centerOffsetX: number,
        sideDirection: number
      ) => {
        const centeredDeltaX = centerOffsetX * centerProgress;
        const sidePhaseDeltaX = sideTravel * sideDirection * sidePhaseProgress;
        const outPhaseDeltaX = outTravel * sideDirection * outPhaseProgress;
        const outPhaseDeltaY = outTravelY * outPhaseProgress;
        const modalDeltaX =
          (sidePhaseDeltaX + outPhaseDeltaX) * familyTransitionProgress;
        const modalDeltaY = outPhaseDeltaY * familyTransitionProgress;
        const deltaX = Number((centeredDeltaX + modalDeltaX).toFixed(2));
        const deltaY = Number(modalDeltaY.toFixed(2));

        el.style.transform = `translate3d(${deltaX}px, ${deltaY}px, 0)`;
      };

      applyModalFamilyTransform(
        familyFatherEl,
        centerOffsetByMember.father,
        sideDirectionByMember.father
      );
      applyModalFamilyTransform(
        familyMotherEl,
        centerOffsetByMember.mother,
        sideDirectionByMember.mother
      );
      applyModalFamilyTransform(
        familyDaughterEl,
        centerOffsetByMember.daughter,
        sideDirectionByMember.daughter
      );
      applyModalFamilyTransform(
        familySisterEl,
        centerOffsetByMember.sister,
        sideDirectionByMember.sister
      );
      applyModalFamilyTransform(
        familyUncleEl,
        centerOffsetByMember.uncle,
        sideDirectionByMember.uncle
      );

      if (familyModalHeader) {
        familyModalHeader.style.opacity = String(eased);
      }
    };
    let smoothProgress = 0;
    let targetProgress = 0;
    let currentZoom = 1;
    let targetZoom = 1;
    let familyTransitionProgress = 0;
    let targetFamilyTransition = 0;
    let frameTranslateY = 0;
    const LERP_FACTOR = 0.08;

    const getScrollProgress = () => {
      const sectionRect = ourTeamSectionEl.getBoundingClientRect();
      const sectionHeight = ourTeamSectionEl.offsetHeight;
      const viewportHeight = window.innerHeight;
      return Math.max(
        0,
        Math.min(1, -sectionRect.top / (sectionHeight - viewportHeight))
      );
    };

    const tick = () => {
      targetProgress = getScrollProgress();
      smoothProgress += (targetProgress - smoothProgress) * LERP_FACTOR;
      currentZoom += (targetZoom - currentZoom) * LERP_FACTOR;
      familyTransitionProgress +=
        (targetFamilyTransition - familyTransitionProgress) * LERP_FACTOR;

      animateTeamFrame(smoothProgress, currentZoom);
      animateFamily(smoothProgress);
      animateSectionContent(smoothProgress);
      animateModalTransition();
      updateCursor(smoothProgress);

      requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);

    // Modal interactions — only available after the section has been scrolled through
    const MODAL_THRESHOLD = 0.8;
    const MODAL_ZOOM = isMobileViewport ? 1.1 : 1.2;
    const MODAL_ZOOM_POST_DELAY = isMobileViewport ? 1.25 : 1.35;

    const openModal = () => {
      if (smoothProgress < MODAL_THRESHOLD) {
        return;
      }

      modal?.show();
      modal?.classList.remove("role-active");
      familyModalLine?.classList.remove("visible");
      document.body.style.overflowY = "hidden";
      teamFrameContainerEl.style.zIndex = "130";
      teamFrameContainerEl.classList.add("modal-open");
      teamFrameContainerEl.classList.remove("hitbox-active");
      if (familyContainer) {
        familyContainer.style.pointerEvents = "none";
        familyContainer.style.opacity = "1";
      }

      targetZoom = MODAL_ZOOM;
      targetFamilyTransition = 1;
      modalOpenTime = performance.now();
    };

    const closeModal = () => {
      modal?.close();
    };

    modal?.addEventListener("close", () => {
      modal.classList.remove("role-active");
      if (familyModalContent) {
        familyModalContent.classList.remove("active");
      }
      if (familyModalDescription) {
        familyModalDescription.textContent = defaultFamilyModalDescription;
      }
      familyModalLine?.classList.remove("visible");

      if (piecePanelBody) {
        piecePanelBody.innerHTML = "";
      }

      document.body.style.overflowY = "";
      modalCloseBtn?.classList.remove("visible");
      teamFrameContainerEl.style.zIndex = "";
      teamFrameContainerEl.classList.remove("modal-open");
      teamFrameContainerEl.classList.remove("hitbox-active");
      if (familyContainer) {
        familyContainer.style.pointerEvents = "";
        familyContainer.style.opacity = "1";
      }

      targetZoom = 1;
      targetFamilyTransition = 0;
      if (tileFloor) {
        tileFloor.style.transform = "";
      }

      frameTranslateY = 0;
      if (familyModalHeader) {
        familyModalHeader.style.opacity = "0";
      }
    });

    modal?.addEventListener("cancel", (e) => {
      e.preventDefault();
    });

    // Update cursor to signal interactability dynamically
    const updateCursor = (progress: number) => {
      if (familyContainer) {
        familyContainer.style.cursor =
          progress >= MODAL_THRESHOLD ? "pointer" : "default";
      }
    };

    familyContainer?.addEventListener("click", (e) => {
