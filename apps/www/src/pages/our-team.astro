      const targetX = getCenteredTargetX();
      let translateX: number;
      if (isMobileViewport) {
        translateX = transform(
          scrollProgress,
          [0, 0.45],
          [targetX + window.innerWidth * 0.75, targetX],
          easeInOutCubic
