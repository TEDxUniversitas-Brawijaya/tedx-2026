      familyHeader.style.opacity = String(headerRevealProgress);
    };

    const syncFamilyWithScroll = (scrollProgress: number) => {
      if (!family) {
        return;
      }

      const shouldShowPiecePanel = scrollProgress >= HEADER_REVEAL_START;

      const canOpenPiecePanel = shouldShowPiecePanel;
      teamFrameContainerEl.classList.toggle("hitbox-active", canOpenPiecePanel);

