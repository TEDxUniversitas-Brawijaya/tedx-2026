---
import Layout from "@/components/layout.astro";
import NavBar from "@/components/navbar.astro";
import Image from "astro/components/Image.astro";
import TileFloor from "@/assets/imgs/tile-floor.png";
import PaperTexture from "@/assets/imgs/paper-texture-1.png";
import GreenBackground from "@/assets/imgs/green-background.png";

import Father from "@/assets/imgs/father.png";
import Mother from "@/assets/imgs/mother.png";
import Sister from "@/assets/imgs/sister.png";
import Uncle from "@/assets/imgs/uncle.png";

import Daughter from "@/assets/imgs/daughter.png";
import EventManagerPiece from "@/assets/imgs/em-piece.png";
import CemPiece from "@/assets/imgs/cem-piece.png";
import BudgetPiece from "@/assets/imgs/budget-piece.png";
import DesignPiece from "@/assets/imgs/design-piece.png";
import CuratorPiece from "@/assets/imgs/curator-piece.png";
import EpPiece from "@/assets/imgs/ep-piece.png";
import OrganizerPiece from "@/assets/imgs/organizer-piece.png";
import SponsorshipPiece from "@/assets/imgs/sponsorship-piece.png";
import VpPiece from "@/assets/imgs/vp-piece.png";
import WebsitePiece from "@/assets/imgs/website-piece.png";
import EmptyPieceTop from "@/assets/imgs/empty-piece-top.png";
import EmptyPieceBottom from "@/assets/imgs/empty-piece-bottom.png";
import EmptyPieceTopRight from "@/assets/imgs/empty-piece-top-right.png";
import VolunteerChip from "@/assets/imgs/volunteer-chip.png";

import Line from "@/assets/imgs/line-1.png";
import TeamFrameBackground from "@/assets/imgs/team-frame-background.png";
---

<Layout
  title="Meet Our Team | TEDx Universitas Brawijaya"
  description="Inilah insan-insan di balik TEDxUniversitasBrawijaya 2026. Bukan sekadar tim, melainkan sebuah keluarga yang Bertumbuh Bersama demi membangun rumah bagi setiap ide yang layak diperjuangkan."
>
  <NavBar />
  <main>
    <section id="our-team">
      <div class="our-team-wrapper">
        <Image src={PaperTexture} alt={"Paper Texture"} class="paper-texture" />
        <Image
          src={GreenBackground}
          alt={"Green Background"}
          class="green-background"
        />
        <Image src={TileFloor} alt={"Tile Floor"} class="tile-floor" />
        <div class="team-frame-container" id="team-frame-container">
        <svg class="team-frame-outline" width="625" height="379" viewBox="0 0 625 379" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="7.07089" y="7.06992" width="610.732" height="364.141" stroke="currentColor" stroke-width="14.1414"/>
        </svg>
          <Image
            src={TeamFrameBackground}
            id={"team-frame-background"}
            class="team-frame-background team-layer"
            alt={"Team Frame Background"}
          />
          <Image
            src={EventManagerPiece}
            id={"event-manager-piece"}
            class="team-piece"
            alt={"Event Manager Piece"}
          />
          <Image
            src={CemPiece}
            id={"cem-piece"}
            class="team-piece"
            alt={"Content & Events Manager Piece"}
          />
          <Image
            src={BudgetPiece}
            id={"budget-piece"}
            class="team-piece"
            alt={"Budget Piece"}
          />
          <Image
            src={CuratorPiece}
            id={"curator-piece"}
            class="team-piece"
            alt={"Curator Piece"}
          />
          <Image
            src={EpPiece}
            id={"ep-piece"}
            class="team-piece"
            alt={"Events Producer Piece"}
          />
          <Image
            src={OrganizerPiece}
            id={"organizer-piece"}
            class="team-piece"
            alt={"Organizer Piece"}
          />
          <Image
            src={DesignPiece}
            id={"design-piece"}
            class="team-piece"
            alt={"Design Piece"}
          />
          <Image
            src={SponsorshipPiece}
            id={"sponsorship-piece"}
            class="team-piece"
            alt={"Sponsorship Piece"}
          />
          <Image
            src={VpPiece}
            id={"vp-piece"}
            class="team-piece"
            alt={"Vice President Piece"}
          />
          <Image
            src={WebsitePiece}
            id={"website-piece"}
            class="team-piece"
            alt={"Website Piece"}
          />
          <div class="piece-hitbox-layer">
            <button
              class="piece-hitbox-btn piece-hitbox-event-manager"
              aria-label="Event Manager"
              data-role="Event Manager"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-cem"
              aria-label="Communication, Editorial & Marketing"
              data-role="Communication, Editorial & Marketing"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-budget"
              aria-label="Budget Manager"
              data-role="Budget Manager"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-curator"
              aria-label="Curator"
              data-role="Curator"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-ep"
              aria-label="Executive Producer"
              data-role="Executive Producer"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-organizer"
              aria-label="Organizer"
              data-role="Organizer,Co-Organizer"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-design"
              aria-label="Design"
              data-role="Design"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-sponsorship"
              aria-label="Sponsorship"
              data-role="Sponsorship"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-vp"
              aria-label="Video Production"
              data-role="Video Production"
            ></button>
            <button
              class="piece-hitbox-btn piece-hitbox-website"
              aria-label="Website"
              data-role="Website"
            ></button>
          </div>
          <Image
            src={EmptyPieceTop}
            id={"empty-piece-top"}
            class="team-empty-piece"
            alt={"Empty Piece Top"}
          />
          <Image
            src={EmptyPieceBottom}
            id={"empty-piece-bottom"}
            class="team-empty-piece"
            alt={"Empty Piece Bottom"}
          />
          <Image
            src={EmptyPieceTopRight}
            id={"empty-piece-top-right"}
            class="team-empty-piece"
            alt={"Empty Piece Top Right"}
          />
        </div>
        <div
          class="family-container"
          id="family-container"
          role="button"
          tabindex="0"
          aria-label="Klik untuk melihat keluarga kami"
        >
          <Image
            src={Father}
            alt="Father"
            class="family-father"
            id="family-father"
            aria-hidden="true"
          />
          <Image
            src={Mother}
            alt="Mother"
            class="family-mother"
            id="family-mother"
            aria-hidden="true"
          />
          <Image
            src={Sister}
            alt="Sister"
            class="family-sister"
            id="family-sister"
            aria-hidden="true"
          />
          <Image
            src={Uncle}
            alt="Uncle"
            class="family-uncle"
            id="family-uncle"
            aria-hidden="true"
          />
         <Image
            src={Daughter}
            alt="Daughter"
            class="family-daughter"
            id="family-daughter"
            aria-hidden="true"
          />
        </div>
        <div class="section-content">
          <h2>DIBALIK KELUARGA TEDX Universitas Brawijaya</h2>
          <p>
            Inilah insan-insan di balik TEDxUniversitasBrawijaya 2026. Bukan
            sekadar tim, melainkan sebuah keluarga yang Bertumbuh Bersama demi
            membangun rumah bagi setiap ide yang layak diperjuangkan.
          </p>
        </div>
      </div>
    </section>
    <dialog id="family-modal" class="family-modal">
      <div class="family-modal-topbar">
        <div class="family-modal-header">
          <h2 class="family-modal-heading">Meet the Team</h2>
          <p class="family-modal-description" id="family-modal-description">
            Setiap divisi memiliki peran penting dalam menghadirkan
            TEDxUniversitasBrawijaya. Klik divisi untuk melihat tim di baliknya.
          </p>
          <Image
            src={Line}
            alt="Line"
            id="family-modal-line"
            class="family-modal-line"
          />
        </div>
        <button
          class="modal-close-btn"
          id="modal-close-btn"
          aria-label="Tutup modal"
        >
          &times;
        </button>
      </div>
      <div class="family-modal-content" id="family-modal-content">
        <div class="piece-panel-separator" aria-hidden="true"></div>
        <div
          class="piece-panel-body"
          id="piece-panel-body"
          data-volunteer-chip-src={VolunteerChip.src}
        ></div>
      </div>
    </dialog>
  </main>
</Layout>
<style>
  #our-team {
    position: relative;
    height: 560dvh;
  }

  .our-team-wrapper {
    position: sticky;
    inset: 0;
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    isolation: isolate;
  }

  .green-background,
  .paper-texture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .paper-texture {
    mix-blend-mode: multiply;
    z-index: 150;
  }

  .tile-floor {
    position: absolute;
    left: 50%;
    bottom: -2%;
    width: min(200rem, 200vw);
    aspect-ratio: 16 / 5;
    transform: translateX(-50%);
    object-fit: cover;
    pointer-events: none;
    will-change: transform;
  }

  .team-frame-container {
    position: absolute;
    top: 38%;
    left:85%;
    width: clamp(40rem, 40vw, 40rem);
    aspect-ratio: 1 / 1;
    transform-origin: center;
    will-change: transform;
  }

  .team-frame-outline {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-red);
    pointer-events: none;
    z-index: 95;
  }

  .team-frame-outline rect {
    stroke: var(--color-red);
  }

  .team-frame-container img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .team-frame {
    z-index: 80;
  }

  .team-layer,
  .team-piece,
  .team-empty-piece {
    transform: translateZ(0) scale(0.96);
  }

  #team-frame-background {
    z-index: 90;
  }

  .team-piece,
  .team-empty-piece {
    z-index: 100;
    pointer-events: none;
  }

  .piece-hitbox-layer {
    position: absolute;
    inset: 2.5%;
    z-index: 130;
  }

  .piece-hitbox-btn {
    position: absolute;
    top: var(--hitbox-y, 50%);
    left: var(--hitbox-x, 50%);
    width: var(--hitbox-w, 10%);
    height: var(--hitbox-h, 10%);
    transform: translate(-50%, -50%);
    background: var(--hitbox-color, rgba(255, 255, 255, 0.25));
    border: 1px dashed rgba(255, 255, 255, 0.9);
    border-radius: 0.3rem;
    padding: 0;
    pointer-events: none;
    cursor: default;
    opacity: 0;
    transition: opacity 0.2s ease-in-out;
  }

  .team-frame-container.hitbox-active .piece-hitbox-btn {
    pointer-events: auto;
    cursor: pointer;
    opacity: 0.38;
  }

  .piece-hitbox-btn:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.85);
    outline-offset: 2px;
  }

  .team-frame-container.hitbox-active .piece-hitbox-btn:hover,
  .team-frame-container.hitbox-active .piece-hitbox-btn:focus-visible {
    opacity: 0.68;
  }

  .piece-hitbox-event-manager {
    --hitbox-color: rgba(255, 99, 71, 0.5);
    --hitbox-x: 33%;
    --hitbox-y: 28%;
    --hitbox-w: 24%;
    --hitbox-h: 15%;
  }

  .piece-hitbox-cem {
    --hitbox-color: rgba(0, 191, 255, 0.5);
    --hitbox-x: 47%;
    --hitbox-y: 50%;
    --hitbox-w: 15%;
    --hitbox-h: 15%;
  }

  .piece-hitbox-budget {
    --hitbox-color: rgba(255, 215, 0, 0.5);
    --hitbox-x: 46%;
    --hitbox-y: 75%;
    --hitbox-w: 35%;
    --hitbox-h: 10%;
  }

  .piece-hitbox-curator {
    --hitbox-color: rgba(186, 85, 211, 0.5);
    --hitbox-x: 30%;
    --hitbox-y: 45%;
    --hitbox-w: 10%;
    --hitbox-h: 15%;
  }

  .piece-hitbox-ep {
    --hitbox-color: rgba(34, 197, 94, 0.5);
    --hitbox-x: 10%;
    --hitbox-y: 30%;
    --hitbox-w: 15%;
    --hitbox-h: 15%;
  }

  .piece-hitbox-organizer {
    --hitbox-color: rgba(249, 115, 22, 0.5);
    --hitbox-x: 10%;
    --hitbox-y: 60%;
    --hitbox-w: 20%;
    --hitbox-h: 35%;
  }

  .piece-hitbox-design {
    --hitbox-color: rgba(16, 185, 129, 0.5);
    --hitbox-x: 80.5%;
    --hitbox-y: 70.5%;
    --hitbox-w: 15%;
    --hitbox-h: 20%;
  }

  .piece-hitbox-sponsorship {
    --hitbox-color: rgba(236, 72, 153, 0.5);
    --hitbox-x: 80%;
    --hitbox-y: 40%;
    --hitbox-w: 20%;
    --hitbox-h: 20%;
  }

  .piece-hitbox-vp {
    --hitbox-color: rgba(99, 102, 241, 0.5);
    --hitbox-x: 65%;
    --hitbox-y: 60%;
    --hitbox-w: 10%;
    --hitbox-h: 10%;
  }

  .piece-hitbox-website {
    --hitbox-color: rgba(6, 182, 212, 0.5);
    --hitbox-x: 95%;
    --hitbox-y: 65%;
    --hitbox-w: 10%;
    --hitbox-h: 30%;
  }

  .team-frame-container.hitbox-active:has(
      .piece-hitbox-event-manager:is(:hover, :focus-visible)
    )
    #event-manager-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-cem:is(:hover, :focus-visible)
    )
    #cem-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-budget:is(:hover, :focus-visible)
    )
    #budget-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-curator:is(:hover, :focus-visible)
    )
    #curator-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-ep:is(:hover, :focus-visible)
    )
    #ep-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-organizer:is(:hover, :focus-visible)
    )
    #organizer-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-design:is(:hover, :focus-visible)
    )
    #design-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-sponsorship:is(:hover, :focus-visible)
    )
    #sponsorship-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-vp:is(:hover, :focus-visible)
    )
    #vp-piece,
  .team-frame-container.hitbox-active:has(
      .piece-hitbox-website:is(:hover, :focus-visible)
    )
    #website-piece {
    filter: brightness(1.4) drop-shadow(0px 4px 25px rgba(255, 149, 0, 0.5));
  }
  
  .family-container{

    /* Desktop placeholders: adjust these values freely */
    --family-father-left: auto;
    --family-father-right: 10vw;
    --family-father-top: 50vh;

    --family-mother-left: auto;
    --family-mother-right: 24vw;
    --family-mother-top: 65vh;

    --family-sister-left: auto;
    --family-sister-right: 0vw;
    --family-sister-top: 60vh;

    --family-uncle-left: auto;
    --family-uncle-right: -5vw;
    --family-uncle-top: 50vh;

    --family-daughter-left: 0%;
    --family-daughter-right: auto;
    --family-daughter-top: 80vh;

    width: 100%;
    height:100%;
    aspect-ratio: 16 / 10;
    object-fit: contain;
    opacity: 1;
    transition:
      opacity 0.15s ease,
      transform 0.35s ease;
    will-change: opacity, transform;
  }

  .family-father,.family-mother,.family-sister,.family-uncle,.family-daughter{
    position:absolute;
    transform: translate3d(0, 0, 0);
    backface-visibility: hidden;
    will-change: transform, opacity;
  }
  .family-father {
    left: var(--family-father-left);
    right: var(--family-father-right);
    top: var(--family-father-top);
  }

  .family-mother {
    left: var(--family-mother-left);
    right: var(--family-mother-right);
    top: var(--family-mother-top);
  }

  .family-sister{
    z-index:2;
    left: var(--family-sister-left);
    right: var(--family-sister-right);
    top: var(--family-sister-top);
  }
  .family-uncle {
    z-index:1;
    left: var(--family-uncle-left);
    right: var(--family-uncle-right);
    top: var(--family-uncle-top);
  }

  .family-daughter {
    left: var(--family-daughter-left);
    right: var(--family-daughter-right);
    top: var(--family-daughter-top);
  }
  .section-content {
    position: absolute;
    top: 50%;
    left: 12%;
    transform: translate(-10%, -50%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.2rem, 2vw, 2.5rem);
    width: clamp(16rem, 28vw, 30rem);
    z-index: 200;
    pointer-events: none;
  }

  .section-content h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2.2vw, 2.2rem);
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.01em;
    color: var(--color-white);
    text-wrap: balance;
  }

  .section-content p {
    font-family: var(--font-sans);
    font-size: clamp(0.85rem, 1vw, 1rem);
    margin: 0;
    font-weight: 400;
    line-height: 1.55;
    color: var(--color-white);
    text-wrap-style: pretty;
  }

  .family-modal {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: unset;
    max-height: unset;
    background: transparent;
    border: none;
    padding: 2rem;
    display: none;
    align-items: center;
    justify-content: flex-start;
    flex-direction: column;
    gap: 1.5rem;
    z-index: 1000;
    color: var(--color-white);
    pointer-events: none;
    overflow-y: auto;
  }

  .family-modal[open] {
    display: flex;
  }

  .family-modal::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    background: rgba(8, 9, 11, 0.32);
    backdrop-filter: blur(0px);
    transition:
      opacity 0.28s ease,
      backdrop-filter 0.28s ease;
  }

  .family-modal > * {
    position: relative;
    z-index: 1;
  }

  .family-modal.role-active::before {
    opacity: 1;
    backdrop-filter: blur(10px);
  }

  .family-modal::backdrop {
    background: transparent;
    pointer-events: none;
  }

  .modal-close-btn {
    position: absolute;
    right: 0;
    display: none;
    border: none;
    background: none;
    padding: 0;
    color: white;
    font-size: 2.2rem;
    cursor: pointer;
    line-height: 1;
    pointer-events: auto;
    z-index: 1100;
    transition: color 0.2s ease;
  }

  .modal-close-btn.visible {
    display: block;
  }

  .modal-close-btn:hover,
  .modal-close-btn:focus-visible {
    color: rgba(255, 255, 255, 0.85);
  }

  .family-modal-topbar {
    width: min(92vw, 50rem);
    margin-top: 4.5rem;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    pointer-events: auto;
  }

  .family-modal-header {
    width: 100%;
    margin-top: 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    opacity: 0;
    pointer-events: none;
  }

  .team-frame-container.modal-open ~ .section-content {
    opacity: 0;
  }

  .family-modal-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.8rem);
    font-weight: 500;
    color: white;
    margin: 0;
  }

  .family-modal-description {
    font-family: var(--font-sans);
    font-size: clamp(0.9rem, 1.8vw, 1.05rem);
    max-width: 46rem;
    margin: 0 auto;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.9);
    text-wrap-style: pretty;
  }

  .family-modal-line {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .family-modal-line.visible {
    opacity: 1;
  }

  .family-modal-content {
    pointer-events: auto;
    position: relative;
    padding: 2rem;
    width: min(92vw, 100%);
    max-width: 92vw;
    max-height: min(78vh, 42rem);
    overflow: hidden;
    display: none;
    flex-direction: column;
    gap: 1.25rem;
    margin-inline: auto;
  }

  .family-modal-content.active {
    display: flex;
  }
  .family-modal-content h2 {
    text-align: center;
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2.2vw, 2.2rem);
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.01em;
    color: white;
    text-wrap: balance;
  }

  .piece-panel-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-white);
    margin: 0;
    padding-right: 2rem;
  }

  .piece-panel-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .piece-panel-body {
    width: 100%;
    margin-inline: auto;
    max-height: min(52vh, 30rem);
    padding-right: 0.35rem;
  }

  .piece-panel-group-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 149, 0, 0.9);
    margin: 0 0 0.3rem;
  }

  .piece-panel-member {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  .volunteer-chip-wrap {
    display: grid;
    grid-template-columns: repeat(auto-fit, 12.5rem);
    justify-content: center;
    gap: 0.5rem;
  }

  .volunteer-chip {
    position: relative;
    width: 12.5rem;
    min-height: 2.35rem;
  }

  .volunteer-chip-bg {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    pointer-events: none;
