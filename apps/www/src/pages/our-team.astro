const createCoreTeamCardFileNames = (role: string, name: string) => {
  const baseName = `core-team-${toCardSlug(role)}--${toCardSlug(name)}`;
  return {
    preferred: `${baseName}-card.png`,
  };
};
const toCardSlug = (value: string) => {
  return value
    .toLowerCase()
    .replaceAll("&", " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
};
