    const openModal = () => {
      if (smoothProgress < MODAL_THRESHOLD) return;
      modal?.show();
      document.body.style.overflowY = "hidden";
      modalCloseBtn?.classList.add("visible");
      (teamFrameContainer as HTMLElement).style.zIndex = "130";
      (teamFrameContainer as HTMLElement).classList.add("modal-open");
      if (familyContainer) familyContainer.style.pointerEvents = "none";
      targetZoom = MODAL_ZOOM;
      targetFamilyTransition = 1;
      modalOpenTime = performance.now();
    };

    const closeModal = () => {
      modal?.close();
