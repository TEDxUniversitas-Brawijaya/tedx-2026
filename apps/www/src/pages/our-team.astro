      moveFamilyMemberToCenter(
        familyMotherEl,
        centerOffsetByMember.mother,
        directionByMember.mother,
        true
      );
      moveFamilyMemberToCenter(
        familyUncleEl,
        centerOffsetByMember.uncle,
        directionByMember.uncle,
        true
      );
      moveFamilyMemberToCenter(
        familySisterEl,
        centerOffsetByMember.sister,
        directionByMember.sister,
        true
      );
      moveFamilyMemberToCenter(
        familyDaughterEl,
        centerOffsetByMember.daughter,
        directionByMember.daughter
      );
