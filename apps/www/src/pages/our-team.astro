      },
      {
        role: "Communication, Editorial & Marketing",
        name: "Maheza Mahardika",
        team: "Volunteer",
      },

      { role: "Sponsorship", name: "Khalilah Ferline", team: "Core Team" },
      { role: "Sponsorship", name: "Kamilah Putri", team: "Core Team" },
      { role: "Sponsorship", name: "Kyara Azzahra", team: "Core Team" },
      { role: "Sponsorship", name: "Imam Fachriza", team: "Core Team" },
      { role: "Sponsorship", name: "Nayla Diandra", team: "Volunteer" },
      { role: "Sponsorship", name: "Andera Early", team: "Volunteer" },
