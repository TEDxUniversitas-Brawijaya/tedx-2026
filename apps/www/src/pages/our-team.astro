      } else {
        translateX = transform(
          scrollProgress,
          [0.2, 0.9],
          [0, targetX],
          easeInOutCubic
        );
      }

      const zoomBoost = transform(
        scrollProgress,
        [0.7, 1],
        [1, 1.4],
        easeInOutCubic
      );
      const frameDropY = transform(
        scrollProgress,
        [0.7, 1],
        [0, isMobileViewport ? 15 : 30],
        easeInOutCubic
      );

      const autoScale = teamFrameContainerEl.clientWidth / DESIGN_WIDTH;
      const finalScale = zoom * autoScale * zoomBoost;

      const roundedTranslateX = Number(translateX.toFixed(2));
      const roundedFrameTranslateY = Number(frameDropY.toFixed(2));
      const roundedScale = Number(finalScale.toFixed(4));

      teamFrameContainerEl.style.transform =
