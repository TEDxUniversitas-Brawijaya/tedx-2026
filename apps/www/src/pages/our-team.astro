      modalCloseBtn?.classList.remove("visible");
      (teamFrameContainer as HTMLElement).style.zIndex = "";
      (teamFrameContainer as HTMLElement).classList.remove("modal-open");
      if (familyContainer) familyContainer.style.pointerEvents = "";
      targetZoom = 1;
      targetFamilyTransition = 0;
      if (tileFloor) tileFloor.style.transform = "";
      familyThreeLeft.style.transform = "";
      familyThreeRight.style.transform = "";
      frameTranslateY = 0;
      if (familyModalHeader) familyModalHeader.style.opacity = "0";
    });

    modal?.addEventListener("cancel", (e) => {
      e.preventDefault();
    });

    // Update cursor to signal interactability dynamically
    const updateCursor = (progress: number) => {
      if (familyContainer) {
        familyContainer.style.cursor =
