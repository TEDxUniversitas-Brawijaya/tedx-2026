    const createInitials = (name: string) => {
      const words = name
        .trim()
        .split(" ")
        .filter((word) => word.length > 0);
      const initials = words
        .slice(0, 2)
        .map((word) => word.charAt(0).toUpperCase())
        .join("");
      return initials || "TM";
    };

    const sanitize = (value: string) => {
      return value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    };

    const showPiecePanel = (roleAttr: string, displayTitle: string) => {
      if (!(familyModalContent && piecePanelBody && modal)) {
        return;
      }

      const roles = roleAttr.split(",").map((r) => r.trim());
      const members = teamMembers.filter((m) => roles.includes(m.role));

      if (familyModalDescription) {
        familyModalDescription.textContent = displayTitle;
      }

      const coreTeam = members.filter((m) => m.team !== "Volunteer");
      const volunteers = members.filter((m) => m.team === "Volunteer");

      const coreCards = coreTeam
        .map((member) => {
          const safeName = sanitize(member.name);
          const initials = sanitize(createInitials(member.name));
          return `<article${scopeAttr} class="member-card"><div${scopeAttr} class="member-card-photo" aria-hidden="true">${initials}</div><p${scopeAttr} class="member-card-name">${safeName}</p></article>`;
        })
        .join("");

      const safeChipSrc = sanitize(volunteerChipSrc);
      const volunteerChips = volunteers
        .map((member) => {
          const safeName = sanitize(member.name);
          return `<article${scopeAttr} class="volunteer-chip"><img${scopeAttr} class="volunteer-chip-bg" src="${safeChipSrc}" alt="" aria-hidden="true" /><p${scopeAttr} class="volunteer-chip-name">${safeName}</p></article>`;
        })
        .join("");

      let html = `<section${scopeAttr}><h2${scopeAttr} class="piece-panel-section-title">Core Team</h2><div${scopeAttr} class="core-team-grid">`;
      html +=
        coreCards ||
        `<article${scopeAttr} class="member-card"><div${scopeAttr} class="member-card-photo" aria-hidden="true">TM</div><p${scopeAttr} class="member-card-name">Soon</p></article>`;
      html += "</div></section>";

      if (volunteerChips) {
        html += `<section${scopeAttr}><h2${scopeAttr} class="piece-panel-section-title">Volunteer</h2><div${scopeAttr} class="volunteer-chip-wrap">`;
        html += volunteerChips;
        html += "</div></section>";
      }

      piecePanelBody.innerHTML = html;
      modal.classList.add("role-active");
      familyModalLine?.classList.add("visible");
      modalCloseBtn?.classList.add("visible");
      familyModalContent.classList.add("active");
    };

    const pieceHitboxBtns =
      document.querySelectorAll<HTMLButtonElement>(".piece-hitbox-btn");
    for (const btn of Array.from(pieceHitboxBtns)) {
      btn.addEventListener("click", (e: Event) => {
        e.stopPropagation();
        if (!modal?.open) {
          return;
        }

        const role = btn.dataset.role;
        const label = btn.getAttribute("aria-label") ?? role ?? "";
        if (role) {
          showPiecePanel(role, label);
        }
      });
    }

    piecePanelClose?.addEventListener("click", (e) => {
      e.stopPropagation();
      closeModal();
    });

    modalCloseBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      closeModal();
    });
  })();
</script>
