# openssl rand -base64 32
ALCHEMY_STATE_TOKEN=your-generated-token-here
ALCHEMY_PASSWORD=your-generated-password-here

# Cloudflare Turnstile (CAPTCHA)
# Always passes, visible
# VITE_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Always fails, visible
# VITE_PUBLIC_TURNSTILE_SITE_KEY=2x00000000000000000000AB
# Always passes, invisible
# VITE_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000BB
# Always fails, invisible
# VITE_PUBLIC_TURNSTILE_SITE_KEY=2x00000000000000000000BB
# Forces interactive challenge, visible
# VITE_PUBLIC_TURNSTILE_SITE_KEY=3x00000000000000000000FF
