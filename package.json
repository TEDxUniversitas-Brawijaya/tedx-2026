{
  "name": "tedx-2026",
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@cloudflare/workers-types": "^4.20260403.1",
    "@types/node": "^25.5.2",
    "alchemy": "catalog:",
    "lefthook": "^2.0.15",
    "typescript": "catalog:",
    "ultracite": "7.0.11"
  },
  "packageManager": "bun@1.3.6",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "check": "bunx ultracite check",
    "fix": "bunx ultracite fix",
    "typecheck": "bun --filter \"*\" typecheck",
    "test": "bun --filter \"*\" test",
    "dev:dash": "bun --filter dashboard --filter api dev",
    "dev:store": "bun --filter store --filter api dev",
    "db:generate": "bun --filter \"@tedx-2026/db\" db:generate"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@tailwindcss/vite": "^4.1.18",
      "@trpc/client": "^11.16.0",
      "@trpc/server": "^11.16.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.90.1",
      "better-auth": "^1.5.6",
      "hono": "^4.10.6",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "tailwindcss": "^4.1.18",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    }
  }
}
